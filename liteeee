            end)
        end

        -- Save gun name before unequipping
        local gunName = resolverGetGunName()

        -- 1) Unequip all tools immediately
        resolverUnequipAll()
        _G.resolverShootBlock = true

        local function onArrived()
            -- 2) Wait shoot delay, then re-equip gun
            task.delay(cfg.resolvershootdelay, function()
                if gunName then
                    resolverEquipTool(gunName)
                end
                -- Small extra wait for equip animation
                task.wait(0.15)
                _G.resolverShootBlock = false
                Library:Notify('Resolver: ready', 1)
            end)
        end

        local rot = hrp.CFrame - hrp.CFrame.Position

        if cfg.resolvermode == "TP" then
            hrp.CFrame = CFrame.new(goalPos) * rot
            Library:Notify('Resolver: teleported', 2)
            onArrived()
        else
            -- Speed (float) mode: lerp through walls using noclip on hrp parts,
            -- then restore collision and stay for staydelay before re-equipping
            local endPos = goalPos

            -- Temporarily disable collision on character so we float through walls
            local collisionMap = {}
            if char then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        collisionMap[part] = part.CanCollide
                        part.CanCollide = false
                    end
                end
            end

            local function restoreCollision()
                if char then
                    for _, part in ipairs(char:GetDescendants()) do
                        if part:IsA("BasePart") and collisionMap[part] ~= nil then
                            part.CanCollide = collisionMap[part]
                        end
                    end
                end
            end

            resolverData.moveConn = RunService.Heartbeat:Connect(function(dt)
                if not hrp or not hrp.Parent then
                    restoreCollision()
                    resolverCleanup(false)
                    return
                end
                local cur  = hrp.Position
                local dist = (endPos - cur).Magnitude
                local r2   = hrp.CFrame - hrp.CFrame.Position
                if dist < 0.5 then
                    hrp.CFrame = CFrame.new(endPos) * r2
                    resolverData.moveConn:Disconnect(); resolverData.moveConn = nil
                    restoreCollision()
                    -- Stay at peek spot for staydelay, then re-equip
                    Library:Notify('Resolver: staying ' .. cfg.resolverstaydelay .. 's', 1)
                    task.delay(cfg.resolverstaydelay, function()
                        onArrived()
                    end)
                    return
                end
                hrp.CFrame = CFrame.new(cur + (endPos - cur).Unit * math.min(cfg.resolverspeed * dt, dist)) * r2
            end)
        end
    end


