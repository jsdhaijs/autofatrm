    end

    local function resolverActivate()
        if not cfg.resolver then return end
        if _G.resolverActive then resolverCleanup(true); return end

        local target  = resolverFindTarget()
        if not target then Library:Notify('Resolver: no target', 2); return end

        local goalPos = resolverFindPosition(target)
        if not goalPos then Library:Notify('Resolver: no LOS found', 2); return end

        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        resolverData.originalCFrame = hrp.CFrame
