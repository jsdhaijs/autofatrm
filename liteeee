    -- Gun selector: scan backpack + character and let user pick
    local function getInventoryGuns()
        local guns = {'Auto-detect'}
        local seen = {}
        local bp   = LocalPlayer:FindFirstChild("Backpack")
        local char = LocalPlayer.Character
        local sources = {}
        if bp then table.insert(sources, bp) end
        if char then table.insert(sources, char) end
        for _, src in ipairs(sources) do
            for _, t in ipairs(src:GetChildren()) do
                if t:IsA("Tool") and not seen[t.Name] then
                    seen[t.Name] = true
                    table.insert(guns, t.Name)
                end
            end
        end
        return guns
    end

