                textLabel.Text = string.sub(fullText, 1, i)
                task.wait(0.02)
            end
            textLabel.Text = ""
        end

        -- Snowflake spawner (TweenService-driven, no per-frame loop)
        local snowRunning = false

        local function spawnSnowflake()
            local size = math.random(4, 10)
            local dot = Instance.new("Frame")
            dot.Size = UDim2.new(0, size, 0, size)
            local startX = math.random(0, 1000) / 1000
            dot.Position = UDim2.new(startX, 0, -0.1, 0)
            dot.BackgroundColor3 = Color3.new(1,1,1)
            dot.BackgroundTransparency = 1
            dot.BorderSizePixel = 0
            dot.AnchorPoint = Vector2.new(0.5, 0.5)
            dot.ZIndex = 999
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(1,0)
            corner.Parent = dot
            dot.Parent = frame

            local drift    = math.random(-100, 100) / 1000
            local fallTime = math.random(250, 450) / 100

            TweenService:Create(dot, TweenInfo.new(fallTime, Enum.EasingStyle.Linear), {
                Position = UDim2.new(startX + drift, 0, 1.1, 0)
            }):Play()
            TweenService:Create(dot, TweenInfo.new(0.4), {BackgroundTransparency = 0.2}):Play()

            task.delay(fallTime - 0.5, function()
                if dot and dot.Parent then
                    TweenService:Create(dot, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
                end
            end)
            task.delay(fallTime, function()
                if dot then dot:Destroy() end
            end)
        end

        -- Snow spawn loop
        task.spawn(function()
            while true do
                if snowRunning then spawnSnowflake() end
                task.wait(SPAWN_RATE)
            end
        end)

        local menuOpen = false

        local function setOverlay(visible)
            if visible == menuOpen then return end
            menuOpen = visible
            if visible then
                snowRunning = true
                fadeIn:Play()
                blurIn:Play()
                task.spawn(typeIn)
            else
                fadeOut:Play()
                blurOut:Play()
                task.spawn(typeOut)
                task.delay(0.5, function() snowRunning = false end)
            end
        end

        -- Poll Library.Toggled (Linoria sets this when menu opens/closes)
        local wasOpen = false
        RunService.Heartbeat:Connect(function()
            local now = Library.Toggled == true
            if now ~= wasOpen then
                wasOpen = now
                setOverlay(now)
            end
        end)
    end

