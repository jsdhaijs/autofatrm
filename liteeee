    local resolverRayParams = RaycastParams.new()
    resolverRayParams.FilterType         = Enum.RaycastFilterType.Exclude
    resolverRayParams.IgnoreWater        = true
    resolverRayParams.RespectCanCollide  = false

    local function resolverHasLOS(from, to, ignore)
        local list = {LocalPlayer.Character}
        if ignore then for _, c in ipairs(ignore) do table.insert(list, c) end end
        resolverRayParams.FilterDescendantsInstances = list
        return workspace:Raycast(from, to - from, resolverRayParams) == nil
    end

    local function resolverFindTarget()
        local myChar = LocalPlayer.Character
        local myHrp  = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHrp then return nil end
        local best, bestDist = nil, math.huge
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                local hum = player.Character:FindFirstChildOfClass("Humanoid")
                if hrp and hum and hum.Health > 0 then
                    if not (cfg.teamcheck and player.Team == LocalPlayer.Team) then
                        local d = (hrp.Position - myHrp.Position).Magnitude
                        if d < bestDist then bestDist = d; best = player end
                    end
                end
            end
        end
        return best
    end

    local function resolverFindPosition(targetPlayer)
        if not targetPlayer or not targetPlayer.Character then return nil end
        local targetHrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not targetHrp then return nil end

        local myChar = LocalPlayer.Character
        local myHrp  = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHrp then return nil end

        local tPos     = targetHrp.Position + Vector3.new(0, 2, 0)
        local myPos    = myHrp.Position
        local ignChars = {targetPlayer.Character}
        local candidates = {}

        local r = cfg.resolverradius

        -- Generate peek offsets from the PLAYER's current position
        -- Horizontal: 8 directions at 4 distances
        -- Vertical: straight up at 3 heights (peek over walls)
        -- Diagonal: up+horizontal combos
        local offsets = {}

        -- Horizontal ring
        for deg = 0, 315, 45 do
            local rad = math.rad(deg)
            local hdir = Vector3.new(math.cos(rad), 0, math.sin(rad))
            for _, frac in ipairs({0.25, 0.5, 0.75, 1.0}) do
                table.insert(offsets, hdir * r * frac)
            end
        end

        -- Straight up (peek over top of wall)
        for _, h in ipairs({4, 8, 12}) do
            table.insert(offsets, Vector3.new(0, h, 0))
        end

        -- Straight down (peek under / below cover / underground target)
        for _, h in ipairs({-4, -8, -12}) do
            table.insert(offsets, Vector3.new(0, h, 0))
        end

        -- Diagonal up+horizontal (peek raised corner)
        for deg = 0, 315, 90 do
            local rad = math.rad(deg)
            local hdir = Vector3.new(math.cos(rad), 0, math.sin(rad))
            for _, h in ipairs({5, 10}) do
                table.insert(offsets, hdir * r * 0.5 + Vector3.new(0, h, 0))
            end
        end

        -- Diagonal down+horizontal (peek below edge / lower floor)
        for deg = 0, 315, 90 do
            local rad = math.rad(deg)
            local hdir = Vector3.new(math.cos(rad), 0, math.sin(rad))
            for _, h in ipairs({-5, -10}) do
                table.insert(offsets, hdir * r * 0.5 + Vector3.new(0, h, 0))
            end
        end

        for _, offset in ipairs(offsets) do
            local testPos = myPos + offset

            -- For mostly-horizontal offsets, snap to floor; vertical offsets keep their height
            if math.abs(offset.Y) < 3 then
                local ground = workspace:Raycast(testPos + Vector3.new(0,6,0), Vector3.new(0,-25,0), resolverRayParams)
                if ground then testPos = ground.Position + Vector3.new(0, 3, 0) end
            end
            -- For downward offsets, ensure we're not inside geometry
            if offset.Y < -3 then
                -- verify the test position isn't solid (basic check)
                local blockCheck = workspace:Raycast(testPos, Vector3.new(0, 2, 0), resolverRayParams)
                if blockCheck then testPos = blockCheck.Position + Vector3.new(0, 0.5, 0) end
            end

            local distToTarget = (testPos - targetHrp.Position).Magnitude
            -- Must be at usable shooting distance (not on top of target)
            if distToTarget >= 6 and resolverHasLOS(testPos, tPos, ignChars) then
                table.insert(candidates, {
                    pos        = testPos,
                    travelDist = (testPos - myPos).Magnitude,
                })
            end
        end

        if #candidates == 0 then return nil end
        -- Prefer minimum travel distance
        table.sort(candidates, function(a, b) return a.travelDist < b.travelDist end)
        return candidates[1].pos
    end

    local function resolverCleanup(returnToOrigin)
        if resolverData.moveConn  then resolverData.moveConn:Disconnect();  resolverData.moveConn  = nil end
