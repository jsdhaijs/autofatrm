local function buyLoadout()
	repeat task.wait() until localent.Alive
	task.wait(1)
	if not localent.Alive then return end

	local dg = Exodus.default_guns or {'rifle', 'flintlock', 'aug'}
	for i, v in dg do
		local status = pguns[v]
		if not status then continue end
		local weapon = status.name:gsub('%s*%- %$%d+', '')
		if lplr and lplr.Backpack and lplr.Character and lplr.Character:FindFirstChild('Humanoid') and (not lplr.Backpack:FindFirstChild(weapon) and not lplr.Character:FindFirstChild(weapon)) then
			utils.purchase('weapon', status.name)
		end
	end

	for i, v in dg do
		local status = pguns[v]
		if not status then continue end
		local ammokey = status.label and status.label:lower() or v:lower()
		local ammodata = ammos[ammokey]
		if not ammodata then
			for k, a in ammos do
				if k:find(v:lower(), 1, true) or v:lower():find(k, 1, true) then
					ammodata = a
					break
				end
			end
		end
		if not ammodata then continue end
		for j = 1, 20 do
			if not localent.Alive then break end
			utils.purchase('ammo', ammodata.name, j == 20)
		end
	end
end

