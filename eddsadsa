	for i, v in Exodus.bots do
		local new = api.getname(v)
		if not new then api.chat('the bot ('..v..') wasn\'t found in this server.'); continue end
		if not table.find(whitelist, new.Name) then
			table.insert(whitelist, new.Name)
		end
	end

	api.chat('successfully whitelisted the bots found.')
end)

for i, v in anims do
	api.new('.' ..i, {'!'..i}, function(player, speed)
		speed = tonumber(speed)
		loadanimation(v, speed);
	end)
end

if Exodus and Exodus.autojoin then
	local config = Exodus.autojoin

	local isingame = function(userid)
		local payload = { userIds = {userid} }
		local response = request({
			Url = 'https://presence.roblox.com/v1/presence/users',
			Method = 'POST',
			Headers = { Cookie = config.cookie, ['Content-Type'] = 'application/json' },
			Body = HttpService:JSONEncode(payload)
		})
		local res = response.Body and HttpService:JSONDecode(response.Body)
		return res and res.userPresences[1] and res.userPresences[1].gameId ~= nil
	end

	local join = function(userid)
		local response = request({
			Url = 'https://presence.roblox.com/v1/presence/users',
			Method = 'POST',
			Headers = { Cookie = config.cookie, ['Content-Type'] = 'application/json' },
			Body = HttpService:JSONEncode({ userIds = {userid} })
		})
		local res = HttpService:JSONDecode(response.Body)
		if res.userPresences and res.userPresences[1] and res.userPresences[1].gameId and res.userPresences[1].gameId ~= game.JobId then
			TeleportService:TeleportToPlaceInstance(game.PlaceId, res.userPresences[1].gameId)
		end
	end

	if config.enabled and config.cookie and config.follow then
		task.spawn(function()
			repeat task.wait()
				if not players:FindFirstChild(config.follow) then
					warn('player left!')
					repeat task.wait(2) until isingame(players:GetUserIdFromNameAsync(config.follow))
					warn('player in game, joining')
					join(players:GetUserIdFromNameAsync(config.follow))
					task.wait(4)
				end
			until not game
		end)
	end
end

loadanimation(default)
