local resolverPrevPos = nil
local resolverPrevTime = nil
local resolvedVelocity = Vector3.zero

local function updateResolver(hrp)
	local currentPosition = hrp.Position
	local currentTime = tick()

	if resolverPrevPos and resolverPrevTime then
		local deltaTime = currentTime - resolverPrevTime
		if deltaTime > 0 then
			resolvedVelocity = (currentPosition - resolverPrevPos) / deltaTime
		end
	end

	resolverPrevPos = currentPosition
	resolverPrevTime = currentTime
end

local resolverCon
local function startResolver()
	if resolverCon then resolverCon:Disconnect() end
	resolverCon = runservice.Heartbeat:Connect(function()
		if target and target.Character and target.Character:FindFirstChild('HumanoidRootPart') then
			updateResolver(target.Character.HumanoidRootPart)
		else
			resolvedVelocity = Vector3.zero
			resolverPrevPos = nil
			resolverPrevTime = nil
		end
	end)
end

local function getResolvedPosition()
	if target and target.Character and target.Character:FindFirstChild('HumanoidRootPart') then
		local hrp = target.Character.HumanoidRootPart
		return hrp.Position + resolvedVelocity * 0.1
	end
	return nil
end

