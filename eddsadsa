local function handleChat(sender, message)
	if not table.find(Exodus.owners, sender.Name) then return end

	local parts = message:split(' ')
	local cmd = parts[1]:lower()
	local args = {}
	for i = 2, #parts do
		table.insert(args, parts[i])
	end

	if commands[cmd] then
		task.spawn(function()
			commands[cmd](sender, table.unpack(args))
		end)
	end
end

