                                            repeat task.wait() until r == 'success' or r == 'owned' or not killing or stop or not localent.Alive
                                        end
                                    end
                                end
                                done = (#guns >= #dg)
                            end
                        until #guns >= #dg or done or not killing or stop or not localent.Alive
                    end

                    if target and target.Character then
                        camera.CameraSubject = target.Character.Humanoid

                        if target.Character:FindFirstChildOfClass('ForceField') then
                            info.Text = 'waiting for forcefield to drop (' .. target.Name .. ')'
                            utils.update(CFrame.new(x(), yy(), x()))
                            repeat task.wait()
                                if not target or not target.Character then break end
                            until not target.Character:FindFirstChildOfClass('ForceField') or not killing or stop
                            return
                        end
                    end

					for _, v in guns do
						if not lplr or not lplr.Character then continue end
						if not target or not target.Character then continue end

						v.Parent = lplr.Character

						if v and v.Ammo and not buyinammo then
							if v.Ammo.Value == 0 and utils.getfullammo(v) ~= 0 then
								info.Text = 'reloading (voiding)'
								utils.reload(v)
								utils.update(CFrame.new(x(), yy(), x()))
								continue
							end

							if target and target.Character and target.Character:FindFirstChild('Head') and target.Character:FindFirstChild('Humanoid') then
								if target.Character:FindFirstChild('GRABBING_CONSTRAINT') then
									local a = target.Character:FindFirstChild('GRABBING_CONSTRAINT')
									if a:GetAttribute('PLAYER_HOLD') then
										local newtargetlol = utils.getname(a:GetAttribute('PLAYER_HOLD'))
										if newtargetlol then
											target = newtargetlol
											info.Text = 'targeting ' .. newtargetlol.Name .. ' as they are holding the target.'
										end
									end
								end

								info.Text = (function()
									local hum = target.Character.Humanoid
									return 'shooting (' .. target.Name .. ') | health: ' .. math.floor((hum.Health / hum.MaxHealth) * 100) .. '% (' .. math.floor(hum.Health) .. '/' .. math.floor(hum.MaxHealth) .. ')\t'
								end)()

								local now = tick()
								local h = false

								if now - autoground.i > 5 then
									autoground.o = now
									autoground.i = now
									autoground.pos = {
										x = seed:NextInteger(-300, 300),
										y = seed:NextInteger(-6, -1),
										z = seed:NextInteger(-300, 300)
									}
								elseif now - autoground.o < 0.3 then
									h = true
								end

								local strafeX = math.random(-17, 17)
								local strafeY = math.random(-17, 17)
								local strafeZ = math.random(-17, 17)

								local resolved_pos = getResolvedPosition() or target_position.p

								utils.update((h and CFrame.new(autoground.pos.x, autoground.pos.y, autoground.pos.z) or (CFrame.new(target_position.p) + Vector3.new(strafeX, strafeY, strafeZ)))
									* CFrame.Angles(math.rad(seed:NextInteger(0, 360)), math.rad(seed:NextInteger(0, 360)), math.rad(seed:NextInteger(0, 360))))

								utils.shoot({
									startposition = resolved_pos + Vector3.new(0, seed:NextInteger(1, 12), 0),
									position = resolved_pos,
									part = target.Character.Head,
									tool = v
								})
							end
						end
                	end
                end
            end

			if stomping and target and target.Character then
				if not bodyeffects.get(target, 'K.O') then
					utils.update(CFrame.new(x(), yy(), x()))
					stomping = false
					camera.CameraSubject = lplr.Character.Humanoid
					info.Text = ''
					target = nil
				end

				if bodyeffects.get(target, 'SDeath') or not players:FindFirstChild(target.Name) then
					utils.update(CFrame.new(x(), yy(), x()))
					stomping = false
					camera.CameraSubject = lplr.Character.Humanoid
					info.Text = ''
					target = nil
				end

				if bodyeffects.get(lplr, 'Reload') then
					utils.update(CFrame.new(x(), yy(), x()))
					camera.CameraSubject = lplr.Character.Humanoid
					return
				end

				if lplr.Character:FindFirstChildOfClass('Tool') then
					for i, v in lplr.Character:GetChildren() do
						if v:IsA('Tool') then v.Parent = lplr.Backpack end
					end
				end

				info.Text = 'stomping (' .. target.Name .. ')'
				utils.update((CFrame.new(target.Character.LowerTorso.Position) * CFrame.Angles(0, math.rad(6), 0)) + Vector3.new(0, (Exodus.multi and math.random(1, 8) or stomp_offset or 4), 0))

				lplr.Character.HumanoidRootPart.Velocity = Vector3.zero
				replicated.MainEvent:FireServer('Stomp')
			end

            if not (killing or stomping) then
                if showtarget then
                    local showpos = show and utils:getposition(players:FindFirstChild(showtarget)) or nil
                    utils.update(showpos and showpos + Vector3.new(0, 4, 4) or CFrame.new(x(), yy(), x()))
                end

                if void and not showtarget then
                    utils.update(CFrame.new(x(), yy(), x()))
                    return
                end
            end
        end)

    until not game
end)

