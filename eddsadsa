replicated.MainEvent.OnClientEvent:Connect(function(name, plr, handle, forced, aimpos, part, _)
	if name ~= 'ClientBullet' then return end
	if not sentry then return end
	if killing or stomping then return end

	if assist and part then
		local victim
		for i, v in players:GetPlayers() do
			if part:IsDescendantOf(v.Character) then victim = v; break end
		end

		if table.find(Exodus.owners, plr.Name) and victim then
            if victim.Name ~= lplr.Name and not table.find(Exodus.owners, victim.Name) and not table.find(whitelist, victim.Name) then
				target = victim
				killing = true
				repeat task.wait() until not killing or stop or not assist
				target = nil
			end
		end
	end

	if sentry and part and not killing then
		local victim
		for i, v in players:GetPlayers() do
			if part:IsDescendantOf(v.Character) then victim = v; break end
		end

		if victim then
            if victim.Name ~= lplr.Name and table.find(Exodus.owners, victim.Name) and not table.find(whitelist, victim.Name) then
				plr = players:GetPlayerFromCharacter(plr)
				killing = true
				target = plr

				repeat task.wait() until not killing or stop or not sentry
				target = nil

				if mode == 'stomp' then
					stomping = true
					target = plr
					repeat task.wait() until not stomping or stop or not sentry
					target = nil
				end

				utils.update(CFrame.new(x(), yy(), x()))
			end
		end
	end
end)

local killauraig = function(plr)
    if not ka then return end
    if stop then return end
    if not localent.Alive then return end
	if not Exodus.owners then return end

    for i, v in Exodus.owners do
        local owner = players:FindFirstChild(v)
        local targ = players:FindFirstChild(plr)

        if not targ or not targ.Character or not targ.Character:FindFirstChild('Humanoid') or not targ.Character:FindFirstChild('HumanoidRootPart') then continue end
        if not owner or not owner.Character or not owner.Character:FindFirstChild('Humanoid') or not owner.Character:FindFirstChild('HumanoidRootPart') then continue end

        if targ.Name == lplr.Name or targ.Name == v or plr == owner.Name or plr == lplr.Name then continue end
        if not targ.Character.HumanoidRootPart or not owner.Character.HumanoidRootPart or (owner.Character.HumanoidRootPart.Position - targ.Character.HumanoidRootPart.Position).Magnitude > karange then continue end
        if targ.Character:FindFirstChild('ForceField') or bodyeffects.get(plr, 'SDeath') or targ.Character:FindFirstChild('GRABBING_CONSTRAINT') or table.find(Exodus.owners, plr) then
            continue
        end

		if table.find(whitelist, targ.Name) then continue end
		if not bodyeffects.get(targ, 'K.O') then
			if killing or target then return end
			target = targ
			killing = true
			repeat task.wait() until not killing or not ka or stop
			if not void then void = true end
		end
    end
end

