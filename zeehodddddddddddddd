-- Client bullet redirection: hook GunHandler.getAim/GetAim so bullets go toward aim-assist/silent-aim target.
-- Workaround: when CBR is off but Silent Aim is on, still redirect via getSilentAimTargetPos() so silent aim works without enabling CBR.
-- Supported game variant (RevClient, DBClient, TGClient): tools use GetAim (PascalCase); we hook both getAim and GetAim so either works.
task.spawn(function()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Modules = ReplicatedStorage:WaitForChild("Modules", 60)
    if not Modules then return end
    local GunHandlerModule = Modules:WaitForChild("GunHandler", 60)
    if not GunHandlerModule then return end
    local GunHandler = require(GunHandlerModule)
    if not GunHandler then return end
    -- RevClient/DBClient/TGClient use GetAim (PascalCase); some games use getAim (camelCase)
    local oldGetAim = GunHandler.getAim or GunHandler.GetAim
    if type(oldGetAim) ~= "function" then return end
    local function hookedGetAim(origin)
        local gm = getConfig() and getConfig().GunModifications
        local cbr = gm and gm.ClientBulletRedirection
        local sa = getConfig() and getConfig().SilentAim
        local useCbr = cbr and cbr.Enabled
        local useSaWorkaround = sa and sa.Enabled and not useCbr
        if not useCbr and not useSaWorkaround then
            return oldGetAim(origin)
        end
        local char = player.Character
        if not char then return oldGetAim(origin) end
        local tool = char:FindFirstChildOfClass("Tool")
        if not tool then return oldGetAim(origin) end
        if useCbr then
            local redirectWeapons = (cbr and cbr.Weapons) or {}
            local inList = false
            for _, weaponName in ipairs(redirectWeapons) do
                if tool.Name == weaponName then inList = true break end
            end
            if not inList then return oldGetAim(origin) end
        end
        local targetPos
        if useCbr then
            targetPos = getBulletRedirectTargetPos()
        else
            targetPos = getSilentAimTargetPos()
        end
        if not targetPos or typeof(targetPos) ~= "Vector3" then return oldGetAim(origin) end
        if useCbr and checkAntiCurve and not checkAntiCurve(targetPos) then return oldGetAim(origin) end
        local dir = targetPos - origin
        if dir.Magnitude < 0.001 then return oldGetAim(origin) end
        return dir.Unit
    end
    GunHandler.getAim = hookedGetAim
    GunHandler.GetAim = hookedGetAim
end)

-- Macro function: I/O key simulation (game zoom keys)
local function handleMacro()
    local macro = getConfig() and getConfig().Macro
    local acceleration = (macro and macro.Acceleration) or 0
    
    if type(acceleration) ~= "number" then
        warn("Invalid Acceleration value") --// To handle a Value and make the variables from table to be enable only using number
        return
    end
    
    local speed = acceleration / 100000
    repeat
        if not (getConfig() and getConfig().Macro and getConfig().Macro.Enabled) then isEnabled = false break end
        task.wait(speed)
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.I, false, game)
        task.wait(speed)
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.O, false, game)
        task.wait(speed)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.I, false, game)
        task.wait(speed)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.O, false, game)
    until not isEnabled or not (getConfig() and getConfig().Macro and getConfig().Macro.Enabled)
end

-- keybinds: only act when the feature's checkbox is enabled
track(UserInputService.InputBegan, function(inp,gp)
    if stopped() or gp then return end
    local cfg = getConfig()
    if inp.KeyCode == getAimKey() then
        if not cfg or not cfg.AimAssist or not cfg.AimAssist.Enabled then return end
        local activationMode = (cfg.AimAssist.Mode) or "Toggle"
        if activationMode == "Hold" then
            enableAimbot()
        else
            toggleAimbot()
        end
    elseif inp.KeyCode == getTriggerKey() then
        if not cfg or not cfg.Triggerbot or not cfg.Triggerbot.Enabled then return end
        local activationMode = (cfg.Triggerbot.Mode) or "Toggle"
        if activationMode == "Hold" then
            enableTriggerbot()
        else
            toggleTriggerbot()
        end
    elseif inp.KeyCode == getMovementKey() then
        if cfg and cfg.Movement and cfg.Movement.Enabled then toggleMovement() end
    elseif inp.KeyCode == getFlyKey() then toggleFly()
    elseif inp.KeyCode == getMacroKey() then
        if not cfg or not cfg.Macro or not cfg.Macro.Enabled then return end
        isEnabled = not isEnabled
        if isEnabled then
            handleMacro()
        end
    end
end)

track(UserInputService.InputEnded, function(inp,gp)
    if stopped() or gp then return end
    local cfg = getConfig()
    if inp.KeyCode == getAimKey() then
        local activationMode = (cfg and cfg.AimAssist and cfg.AimAssist.Mode) or "Toggle"
        if activationMode == "Hold" then
            disableAimbot()
        end
    elseif inp.KeyCode == getTriggerKey() then
        local activationMode = (cfg and cfg.Triggerbot and cfg.Triggerbot.Mode) or "Toggle"
        if activationMode == "Hold" then
            disableTriggerbot()
        end
    end
end)

