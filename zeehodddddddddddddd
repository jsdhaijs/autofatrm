-- Adonis Anti-Cheat Bypass
local _isExecutorFunc = typeof(is_synapse_function) == "function" and is_synapse_function or (typeof(is_executor_closure) == "function" and is_executor_closure or function() return false end)

local function BypassAdonis()
    local Detected = nil

    -- Method 1: Find Detected function by known constants (" - On Xbox", " - On mobile")
    for _, v in getgc(true) do
        if typeof(v) == "function" and islclosure(v) then
            local ok, isExec = pcall(_isExecutorFunc, v)
            if ok and isExec then continue end

            local cOk, Constants = pcall(getconstants, v)
            if not cOk or typeof(Constants) ~= "table" then continue end

            local hasXbox = table.find(Constants, " - On Xbox")
            local hasMobile = table.find(Constants, " - On mobile")
            local hasUnderscore = table.find(Constants, "_")

            if (hasXbox or hasMobile) and hasUnderscore then
                Detected = v
                break
            end
        end
    end

    -- Method 2: Search GC tables for a key named "Detected" that holds a function
    if not Detected then
        for _, v in getgc(true) do
            if typeof(v) == "table" then
                local ok, DetectFunc = pcall(rawget, v, "Detected")
                if ok and typeof(DetectFunc) == "function" then
                    Detected = DetectFunc
                    break
                end
            end
        end
    end

    -- Method 3: Look for the Adonis core function that references "Detected", "Kick", "IsStudio"
    -- and then pull the Detected closure from its upvalues
    if not Detected then
        for _, v in getgc(true) do
            if typeof(v) == "function" and islclosure(v) then
                local ok, isExec = pcall(_isExecutorFunc, v)
                if ok and isExec then continue end

                local cOk, Constants = pcall(getconstants, v)
                if not cOk or typeof(Constants) ~= "table" then continue end

                if table.find(Constants, "Detected") and table.find(Constants, "Kick") then
                    -- Try to find the Detected function in upvalues
                    local uOk, ups = pcall(getupvalues, v)
                    if uOk and typeof(ups) == "table" then
                        for _, upval in ups do
                            if typeof(upval) == "function" then
                                local uc, uConsts = pcall(getconstants, upval)
                                if uc and typeof(uConsts) == "table" then
                                    if table.find(uConsts, " - On Xbox") or table.find(uConsts, " - On mobile") then
                                        Detected = upval
                                        break
                                    end
                                end
                            elseif typeof(upval) == "table" then
                                local tOk, fn = pcall(rawget, upval, "Detected")
                                if tOk and typeof(fn) == "function" then
                                    Detected = fn
                                    break
                                end
                            end
                        end
                    end
                    if Detected then break end
                end
            end
        end
    end

    if not Detected then
        return false -- Signal that we didn't find it so retry logic can try again
    end

    local REnv = getrenv()
    local iDetour = REnv.debug.info
    local origDetected = Detected

    -- Get original debug.info return values for Detected function
    local a, b, c, d, e, f
    local success = pcall(function()
        a, b, c, d, e, f = iDetour(origDetected, "slanf")
    end)

    if not success then
        a, b, c, d, e, f = nil, nil, nil, nil, nil, nil
    end

    -- Hook debug.info to spoof values when Adonis checks the Detected function
    local hookSuccess = pcall(function()
        hookfunction(REnv.debug.info, newcclosure(function(...)
            local Args = {...}
            if Args[1] == origDetected and Args[2] == "slanf" then
                return a, b, c, d, e, f
            end
            return iDetour(...)
        end))
    end)

    -- Hook the Detected function itself so it never triggers a kick
    local detHookSuccess = pcall(function()
        hookfunction(origDetected, newcclosure(function()
            return task.wait(9e10)
        end))
    end)

    if hookSuccess or detHookSuccess then
        print("Adonis Bypass Loaded")
        return true
    end

    return false
end

-- Retry loop: keep trying until bypass succeeds or max attempts reached
local adonisBypassed = false
task.spawn(function()
    local maxAttempts = 10
    local delays = {0, 1, 2, 3, 5, 5, 5, 5, 5, 5}
    for attempt = 1, maxAttempts do
        if adonisBypassed then break end
        if attempt > 1 then
            task.wait(delays[attempt] or 5)
        end
        pcall(function()
            setthreadidentity(2)
        end)
        local ok, result = pcall(BypassAdonis)
        if ok and result == true then
            adonisBypassed = true
            break
        end
        pcall(function()
            setthreadidentity(7)
        end)
    end
    if not adonisBypassed then
        print("Adonis bypass - Could not find Adonis after all attempts ")
    end
end)

