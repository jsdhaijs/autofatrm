-- Enhanced prediction for silent aim Ã¢â‚¬â€œ X,Y axis
local function predictSilentAim(pos, part, char, distance)
    if not char then
        char = part.Parent
        if not char or not char:IsA("Model") then
            char = part:FindFirstAncestorWhichIsA("Model")
        end
    end
    
    if not char then return pos end
    
    -- No prediction: use raw position (for hitscan or when prediction causes misses)
    local sa = getConfig() and getConfig().SilentAim
    if not (sa and sa.UsePrediction ~= false) then
        return pos
    end
    
    -- Get velocity with better accuracy
    local vel = getVelocity(part, char)
    
    local predValue = getSilentAimPrediction()
    -- Apply distance multiplier for both manual and auto: at long range target moves more in the same time, so scale prediction up slightly
    if distance and distance > 0 then
        local distanceMultiplier = math.clamp(0.8 + (distance / 500), 0.8, 1.5)
        predValue = predValue * distanceMultiplier
    end
    
    -- Less aggressive velocity filtering - trust the resolver more
    local horizontalVel = Vector3.new(vel.X, 0, vel.Z).Magnitude
    local verticalVel = math.abs(vel.Y)
    
    -- Only filter extremely obvious spoofed velocity
    if verticalVel > 200 and horizontalVel < 15 then
        vel = Vector3.new(vel.X, vel.Y * 0.3, vel.Z)
    elseif verticalVel > 150 and horizontalVel < 10 then
        vel = Vector3.new(vel.X, vel.Y * 0.5, vel.Z)
    end
    
    local lead = vel * predValue
    
    -- Improved Y dampening - less aggressive for better accuracy
    local vy = vel.Y
    local vyAbs = math.abs(vy)
    local damp = 1
    
    -- Handle downward velocity (falling) - less aggressive to maintain accuracy
    if vy < 0 then
        if vyAbs > 60 then
            damp = math.clamp(0.4 + (vyAbs / 2000), 0.4, 0.7) -- Less aggressive
        elseif vyAbs > 25 then
            damp = math.clamp(0.6 + (vyAbs / 800), 0.6, 0.85) -- Moderate
        else
            damp = 0.9 -- Light dampening
        end
    -- Handle upward velocity (jumping)
    elseif vy > 100 then
        damp = math.clamp(0.4 + (vyAbs / 1200), 0.4, 0.75)
    elseif vyAbs < 15 then
        damp = 1
    else
        damp = math.clamp(0.7 + (vyAbs / 300), 0.7, 1)
    end
    
    lead = Vector3.new(lead.X, lead.Y * damp, lead.Z)
    
    -- More generous lead cap for better accuracy
    if lead.Magnitude > 14 * 1.2 then
        lead = lead.Unit * (14 * 1.2)
    end
    
    -- Less restrictive Y cap; when target is falling, no downward lead (prevents ground shots)
    if lead.Y < 0 then
        if vy < 0 then
            lead = Vector3.new(lead.X, 0, lead.Z)
        elseif lead.Y < -10 then
            lead = Vector3.new(lead.X, -10, lead.Z)
        end
    elseif lead.Y > 15 then
        lead = Vector3.new(lead.X, 15, lead.Z)
    end
    
    return pos + lead
end

-- prediction (aim assist) Ã¢â‚¬â€œ single value
local function predict(pos, part, predictionAmount)
    -- Get character for velocity prediction
    local char = part.Parent
    if not char or not char:IsA("Model") then
        char = part:FindFirstAncestorWhichIsA("Model")
    end
    
    local predValue = (type(predictionAmount) == "number" and predictionAmount) or getPredictionValue()
    
    -- Get velocity based on resolver type
    local vel = getVelocity(part, char)
    
    -- Less aggressive spoofed velocity detection - only filter extreme cases
    -- This allows more legitimate movement through for better anti-aim handling
    local horizontalVel = Vector3.new(vel.X, 0, vel.Z).Magnitude
    local verticalVel = math.abs(vel.Y)
    
    -- Only filter extremely obvious spoofed velocity (very high vertical with no horizontal)
    if verticalVel > 150 and horizontalVel < 20 then
        -- Extremely likely spoofed - reduce Y component
        vel = Vector3.new(vel.X, vel.Y * 0.2, vel.Z)
    elseif verticalVel > 100 and horizontalVel < 10 then
        -- Very likely spoofed - reduce Y component moderately
        vel = Vector3.new(vel.X, vel.Y * 0.4, vel.Z)
    end
    
    local lead = vel * predValue

    -- Y dampening - handle both upward and downward predictions
    local vy = vel.Y
    local vyAbs = math.abs(vy)
    local damp = 1
    
    -- Handle downward velocity (falling) - more aggressive dampening to prevent ground shots
    if vy < 0 then
        -- When target is falling, reduce downward prediction more aggressively
        if vyAbs > 50 then
            damp = math.clamp(0.2 + (vyAbs / 1500), 0.2, 0.5) -- More aggressive for fast falls
        elseif vyAbs > 20 then
            damp = math.clamp(0.4 + (vyAbs / 500), 0.4, 0.7) -- Moderate for slower falls
        else
            damp = 0.8 -- Light dampening for slow falls
        end
    -- Handle upward velocity (jumping) - less aggressive dampening
    elseif vy > 80 then
        damp = math.clamp(0.3 + (vyAbs / 1000), 0.3, 0.6) -- Less aggressive damping
    elseif vyAbs < 12 then
        damp = 1
    else
        damp = math.clamp(0.5 + (vyAbs / 200), 0.5, 1) -- Less aggressive damping
    end

    lead = Vector3.new(lead.X, lead.Y * damp, lead.Z)

    -- max lead cap (also cap Y component separately to prevent shooting up)
    if lead.Magnitude > 14 then
        lead = lead.Unit * 14
    end

    -- Y cap: when target is falling, no downward lead (prevents ground shots)
    if lead.Y < 0 then
        if vy < 0 then
            lead = Vector3.new(lead.X, 0, lead.Z)
        elseif lead.Y < -8 then
            lead = Vector3.new(lead.X, -8, lead.Z)
        end
    elseif lead.Y > 12 then
        -- Less restrictive upward cap
        lead = Vector3.new(lead.X, math.sign(lead.Y) * 12, lead.Z)
    end

    return pos + lead
end
