-- easing functions (normalized 0-1 input, returns eased 0-1 output)
-- Easing direction helpers
local function applyEasingDirection(easingFunc, t, direction)
    t = math.clamp(t, 0, 1)
    
    if direction == "In" or direction == 0 then
        return easingFunc(t)
    elseif direction == "Out" or direction == 1 then
        return 1 - easingFunc(1 - t)
    elseif direction == "InOut" or direction == 2 then
        if t < 0.5 then
            return easingFunc(t * 2) / 2
        else
            return 1 - easingFunc((1 - t) * 2) / 2
        end
    else
        return easingFunc(t)
    end
end

-- Base easing functions (without direction) - matches Roblox Enum.EasingStyle
local BaseEasingFunctions = {
    Linear = function(t) 
        t = math.clamp(t, 0, 1)
        return t 
    end,
    Sine = function(t) 
        t = math.clamp(t, 0, 1)
        return 1 - math.cos(t * math.pi / 2) 
    end,
    Back = function(t) 
        t = math.clamp(t, 0, 1)
        local c1 = 1.70158
        local c3 = c1 + 1
        return c3 * t * t * t - c1 * t * t
    end,
    Quad = function(t) 
        t = math.clamp(t, 0, 1)
        return t * t 
    end,
    Quart = function(t) 
        t = math.clamp(t, 0, 1)
        return t * t * t * t 
    end,
    Quint = function(t) 
        t = math.clamp(t, 0, 1)
        return t * t * t * t * t 
    end,
    Bounce = function(t)
        t = math.clamp(t, 0, 1)
        local n1 = 7.5625
        local d1 = 2.75
        if t < 1 / d1 then
            return n1 * t * t
        elseif t < 2 / d1 then
            local t2 = t - 1.5 / d1
            return n1 * t2 * t2 + 0.75
        elseif t < 2.5 / d1 then
            local t2 = t - 2.25 / d1
            return n1 * t2 * t2 + 0.9375
        else
            local t2 = t - 2.625 / d1
            return n1 * t2 * t2 + 0.984375
        end
    end,
    Elastic = function(t)
        t = math.clamp(t, 0, 1)
        local c4 = (2 * math.pi) / 3
        if t == 0 then
            return 0
        elseif t == 1 then
            return 1
        else
            return -math.pow(2, 10 * t - 10) * math.sin((t * 10 - 10.75) * c4)
        end
    end,
    Exponential = function(t)
        t = math.clamp(t, 0, 1)
        if t == 0 then
            return 0
        elseif t == 1 then
            return 1
        else
            return math.pow(2, 10 * (t - 1))
        end
    end,
    Circular = function(t) 
        t = math.clamp(t, 0, 1)
        return 1 - math.sqrt(1 - t * t) 
    end,
    Cubic = function(t) 
        t = math.clamp(t, 0, 1)
        return t * t * t 
    end,
}

-- Get easing function with direction support
local function getEasingFunction(style, direction)
    style = style or "Linear"
    direction = direction or "Out"
    
    -- Use new style system with direction
    local baseFunc = BaseEasingFunctions[style]
    if not baseFunc then
        baseFunc = BaseEasingFunctions.Linear
    end
    
    return function(t) return applyEasingDirection(baseFunc, t, direction) end
end

-- aim assist
local mouseConn = nil
local lastMousePos = nil -- Store last mouse position for smooth interpolation

-- Mouse-based aim assist: moves the mouse cursor to target
local function updateMouse()
    -- When macro is active (any variety), don't override mouse so user can look around e.g. in first person
    local macro = getConfig() and getConfig().Macro
    if macro and macro.Enabled and isEnabled then return end
    local aa = getConfig() and getConfig().AimAssist
    if not (aa and aa.Enabled) then if aimEnabled then disableAimbot() end return end
    -- Hold mode: only active while key is held; check every frame so release is detected reliably
    if aimEnabled and aa and aa.Mode == "Hold" then
        local ok, keyDown = pcall(function() return UserInputService:IsKeyDown(getAimKey()) end)
        if not (ok and keyDown) then
            disableAimbot()
            return
        end
    end
    -- Check if required weapon is equipped
    if not hasRequiredWeapon() then
        disableAimbot()
        return
    end
    
    -- Check if reloading - disable aim assist while reloading
    if isReloading() then
        return
    end
    
-- Check if local player is knocked - disable aim assist while knocked
    if isLocalPlayerKnocked() then
        return
    end
    
    -- Disable when chat or any text box is focused
    if isChatFocused() then return end

    -- Check if target is knocked/grabbed first and unlock immediately
    if lockedTarget then
        local char = getChar(lockedTarget)
        if char and isKnockedOrGrabbed(char) then
            lockedTarget = nil
            cachedWallCheck = true
            lastMousePos = nil
            return
        end
    end
    
    local pos = getLockedTargetPos()
    if not pos then
        -- Check if locked target is still valid but just out of range or behind wall
        if lockedTarget then
            local char = getChar(lockedTarget)
            if char and isAlive(lockedTarget) and not isKnockedOrGrabbed(char) then
                -- Target is valid but pos is nil (out of range, behind wall, etc.)
                return
            end
        end
        
        -- No target: in Hold mode try to acquire; in Toggle mode disable when we lose target
        if not lockedTarget and aimEnabled then
            local aa = getConfig() and getConfig().AimAssist
            local activationMode = (aa and aa.Mode) or "Toggle"
            if activationMode == "Hold" then
                local tgt = findClosestTarget()
                if tgt then
                    lockedTarget = tgt
                    local res = getConfig() and getConfig().Resolver
                    if res and res.Enabled and res.ResolverType == "AttenuateVelocity" then
                        AttenuateVelocityResolver.Assign(tgt)
                    end
                    pos = getLockedTargetPos()
                end
            end
            if not pos then
                if activationMode ~= "Hold" then
                    aimEnabled = false
                    lastMousePos = nil
                    if mouseConn then mouseConn:Disconnect() mouseConn = nil end
                end
                return
            end
        else
            return
        end
    end
    
    -- Convert world position to screen coordinates
    local screenPos, onScreen = camera:WorldToViewportPoint(pos)
    if not onScreen then 
        lastMousePos = nil
        return 
    end
    
    local targetScreenPos = Vector2.new(screenPos.X, screenPos.Y)
    local currentCursorPos = getCursorPos()
    
    -- Apply deadzone check (only when target is on-screen)
    if aa and aa.Deadzone == true and type(aa.DeadzoneAmount) == "number" and aa.DeadzoneAmount > 0 and onScreen then
        local screenDistance = (targetScreenPos - currentCursorPos).Magnitude
        if screenDistance <= aa.DeadzoneAmount then
            lastMousePos = currentCursorPos
            return -- Target is within deadzone, don't move mouse
        end
    end
    
    -- Calculate distance to move
    local delta = targetScreenPos - currentCursorPos
    local distance = delta.Magnitude
    
    if distance < 0.5 then 
        lastMousePos = currentCursorPos
        return -- Already close enough
    end
    
    -- Smoothness X/Y: separate horizontal and vertical lerp (0 = snappy, 100 = smooth)
    local lerpX = math.clamp((aa and aa.SmoothnessX) or 0.2, 0.005, 1)
    local lerpY = math.clamp((aa and aa.SmoothnessY) or 0.2, 0.005, 1)
    if aa and aa.StickyAim == true and distance <= (aa.StickyRadius or 80) then
        lerpX = math.min(1, lerpX * 2.5)
        lerpY = math.min(1, lerpY * 2.5)
    end
    local moveDelta = Vector2.new(delta.X * lerpX, delta.Y * lerpY)
    
    -- Only skip move if delta is negligible; use lower threshold so high smoothness (98+) still moves and reaches target
    local moveThreshold = (distance < 15) and 0.01 or 0.05
    if moveDelta.Magnitude < moveThreshold then 
        lastMousePos = currentCursorPos
        return 
    end
    
    -- Move mouse using mousemoverel (if available)
    if mousemoverel then
        mousemoverel(moveDelta.X, moveDelta.Y)
        lastMousePos = currentCursorPos + moveDelta
    else
        -- Fallback: try to use UserInputService (may not work in all executors)
        pcall(function()
            -- Note: Direct mouse movement may not be available in all executors
            lastMousePos = currentCursorPos + moveDelta
        end)
    end
end

-- Camera-based aim assist: moves the camera to target
local function updateCamera()
    local aa = getConfig() and getConfig().AimAssist
    if not (aa and aa.Enabled) then if aimEnabled then disableAimbot() end return end
    -- Hold mode: only active while key is held; check every frame so release is detected reliably
    if aimEnabled and aa and aa.Mode == "Hold" then
        local ok, keyDown = pcall(function() return UserInputService:IsKeyDown(getAimKey()) end)
        if not (ok and keyDown) then
            disableAimbot()
            return
        end
    end
    -- Check if required weapon is equipped
    if not hasRequiredWeapon() then
        disableAimbot()
        return
    end
    
    -- Check if reloading - disable aim assist while reloading
    if isReloading() then
        return
    end
    
    -- Check if local player is knocked - disable aim assist while knocked
    if isLocalPlayerKnocked() then
        return
    end
    
    -- Disable when chat or any text box is focused
    if isChatFocused() then return end

    -- Check if target is knocked/grabbed first and unlock immediately
    if lockedTarget then
        local char = getChar(lockedTarget)
        if char and isKnockedOrGrabbed(char) then
            lockedTarget = nil
            cachedWallCheck = true
            return
        end
    end
    
    local pos = getLockedTargetPos()
    if not pos then
        -- Check if locked target is still valid but just out of range or behind wall
        if lockedTarget then
            local char = getChar(lockedTarget)
            if char and isAlive(lockedTarget) and not isKnockedOrGrabbed(char) then
                -- Target is valid but pos is nil (out of range, behind wall, etc.)
                return
            end
        end
        -- No target: in Hold mode try to acquire; in Toggle mode disable when we lose target
        if not lockedTarget and aimEnabled then
            local aa = getConfig() and getConfig().AimAssist
            local activationMode = (aa and aa.Mode) or "Toggle"
            if activationMode == "Hold" then
                local tgt = findClosestTarget()
                if tgt then
                    lockedTarget = tgt
                    local res = getConfig() and getConfig().Resolver
                    if res and res.Enabled and res.ResolverType == "AttenuateVelocity" then
                        AttenuateVelocityResolver.Assign(tgt)
                    end
                    pos = getLockedTargetPos()
                end
            end
            if not pos then
                if activationMode ~= "Hold" then
                    aimEnabled = false
                    if camConn then camConn:Disconnect() camConn = nil end
                end
                return
            end
        else
            return
        end
    end
    
    -- Offscreen check: only move camera when target is on screen (don't spin to targets behind you)
    local targetScreen, onScreen = camera:WorldToViewportPoint(pos)
    if not onScreen then
        return
    end
    
    local aa = getConfig() and getConfig().AimAssist
    -- Smoothness X/Y: use average for camera lerp (same scale as mouse)
    local lerpX = math.clamp((aa and aa.SmoothnessX) or 0.2, 0.005, 1)
    local lerpY = math.clamp((aa and aa.SmoothnessY) or 0.2, 0.005, 1)
    do
        local worldPos = targetScreen
        if onScreen then
            local cursorPos = getCursorPos()
            local screenDistance = (Vector2.new(cursorPos.X, cursorPos.Y) - Vector2.new(worldPos.X, worldPos.Y)).Magnitude
            if aa and aa.StickyAim == true and screenDistance <= (aa.StickyRadius or 80) then
                lerpX = math.min(1, lerpX * 2.5)
                lerpY = math.min(1, lerpY * 2.5)
            end
        end
    end
    local lerpFactor = (lerpX + lerpY) * 0.5
    
    -- Apply deadzone check: check screen distance from cursor to target (target is already on screen here)
    if aa and aa.Deadzone == true and type(aa.DeadzoneAmount) == "number" and aa.DeadzoneAmount > 0 then
        local cursorPos = getCursorPos()
        local screenDistance = (Vector2.new(cursorPos.X, cursorPos.Y) - Vector2.new(targetScreen.X, targetScreen.Y)).Magnitude
        if screenDistance <= aa.DeadzoneAmount then
            return
        end
    end
    
    -- Calculate how far we are from the target (0 = aligned, 1 = 180 degrees away)
    local currentLook = camera.CFrame.LookVector
    local goalLook = (pos - camera.CFrame.Position).Unit
    local dot = math.clamp(currentLook:Dot(goalLook), -1, 1)
    
    -- Safety check for NaN or invalid values
    if dot ~= dot or dot > 1 or dot < -1 then
        return
    end
    
    local angle = math.acos(dot)
    
    -- Safety check for NaN angle
    if angle ~= angle or angle < 0 or angle > math.pi then
        return
    end
    
    local goal = CFrame.lookAt(camera.CFrame.Position, pos)
    camera.CFrame = camera.CFrame:Lerp(goal, lerpFactor)
end

-- silent aim
-- Anti Curve: Check if target is within angular curve threshold
local function checkAntiCurve(targetPos)
    local ac = getConfig() and getConfig().AntiCurve
    if not ac or not ac.Enabled then
        return true -- Anti curve disabled, allow all targets
    end
    
    if not targetPos then
        return true
    end
    
    local origin = camera.CFrame.Position
    local cameraDirection = camera.CFrame.LookVector
    local toTarget = targetPos - origin
    local distance = toTarget.Magnitude
    
    -- Check if target is too close (avoid division issues)
    if distance < 0.01 then
        return true
    end
    
    local targetDirection = toTarget.Unit
    local angularDistance = 0
    local mode = ac.Mode or "3D"
    
    if mode == "2D" then
        -- 2D mode: Only consider horizontal plane (X and Z components)
        local cameraDir2D = Vector3.new(cameraDirection.X, 0, cameraDirection.Z)
        local targetDir2D = Vector3.new(targetDirection.X, 0, targetDirection.Z)
        
        local cameraMag2D = cameraDir2D.Magnitude
        local targetMag2D = targetDir2D.Magnitude
        
        -- Handle edge case where vectors have no horizontal component
        if cameraMag2D < 0.001 or targetMag2D < 0.001 then
            return true -- Allow if no horizontal component
        end
        
        cameraDir2D = cameraDir2D / cameraMag2D
        targetDir2D = targetDir2D / targetMag2D
        
        -- Calculate angle in horizontal plane
        local dot = math.clamp(cameraDir2D:Dot(targetDir2D), -1, 1)
        angularDistance = math.deg(math.acos(dot))
    else
        -- 3D mode: Full 3D angle calculation
        local dot = math.clamp(cameraDirection:Dot(targetDirection), -1, 1)
        angularDistance = math.deg(math.acos(dot))
    end
    
    -- Handle NaN cases
    if angularDistance ~= angularDistance then
        return true
    end
    
    -- Check if angular distance is within threshold
    local maxAngle = ac.AngularCurve or 6.0
    return angularDistance <= maxAngle
end

-- FOV mode throttle: avoid running expensive scan every frame (cache result for 2 frames ~= 0.03s at 60fps)
local _fovSilentAimCacheTarget = nil
local _fovSilentAimCacheTime = 0
local FOV_SILENT_AIM_CACHE_INTERVAL = 0.035
local _fovSilentAimCachePos = nil
local _fovSilentAimCachePosTime = 0

-- Find closest target for silent aim using visual FOV
local function findSilentAimTarget()
    local sa = getConfig() and getConfig().SilentAim
    if not (sa and sa.Enabled) then return nil end
    if (sa.Mode or "Target") ~= "FOV" then
        _fovSilentAimCacheTarget = nil
        _fovSilentAimCacheTime = 0
    end
    local now = tick()
    if now - _fovSilentAimCacheTime < FOV_SILENT_AIM_CACHE_INTERVAL and _fovSilentAimCacheTarget ~= nil then
        return _fovSilentAimCacheTarget
    end

    local priority = (getConfig() and getConfig().SilentAim and getConfig().SilentAim.TargetPriority) or "Closest to crosshair"
    local cursor = getCursorPos()
    local origin = camera.CFrame.Position
    local maxFov = getMaxVisualFOV()
    local candidates = {}

    for _,target in getAllTargets() do
        local char = getChar(target)
        if not char then continue end
        
        local humanoid = char:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        if isKnockedOrGrabbed(char) then continue end
        if hasForceField(char) then continue end
        if typeof(target) == "Instance" and target:IsA("Player") and isFriend(target) then continue end
        
        local head = char:FindFirstChild("Head")
        local checks = (getConfig() or {}).Checks
        if not head or (checks and checks.WallCheck and not partVisible(head)) then continue end
        
        if getConfig() and getConfig().Range and getConfig().Range.Enabled then
            local dist = (head.Position - origin).Magnitude
            if dist > ((getConfig() and getConfig().Range and getConfig().Range.Range) or 1000) then continue end
        end
        
        local scr,on = camera:WorldToViewportPoint(head.Position)
        if not on then continue end
        local cursorDist = (Vector2.new(scr.X,scr.Y) - cursor).Magnitude
        if cursorDist >= maxFov then continue end
        
        local distToCam = (head.Position - origin).Magnitude
        candidates[#candidates + 1] = { target = target, cursorDist = cursorDist, health = humanoid.Health, distance = distToCam }
    end
    if #candidates == 0 then _fovSilentAimCacheTarget = nil _fovSilentAimCacheTime = now return nil end
    if priority == "Closest to crosshair" then
        table.sort(candidates, function(a,b) return a.cursorDist < b.cursorDist end)
    elseif priority == "Lowest HP" then
        table.sort(candidates, function(a,b) return a.health < b.health end)
    else
        table.sort(candidates, function(a,b) return a.distance < b.distance end)
    end
    _fovSilentAimCacheTarget = candidates[1].target
    _fovSilentAimCacheTime = now
    return candidates[1].target
end

-- Function to get target position for silent aim. forDisplay=true: for snapline only, skip hitchance and do not update cache.
local function getSilentAimTargetPos(forDisplay)
    local sa = getConfig() and getConfig().SilentAim
    if not (sa and sa.Enabled) then return nil end
    
    -- Check if required weapon is in inventory
    if not hasRequiredWeapon() then return nil end
    
    -- Check if reloading - disable silent aim while reloading
    if isReloading() then return nil end
    
    -- Check if local player is knocked - disable silent aim while knocked
    if isLocalPlayerKnocked() then return nil end
    
    -- Disable when chat or any text box is focused
    if isChatFocused() then return nil end
    
    local target = nil
    local mode = (sa and sa.Mode) or "Target"
    
    -- Target mode: requires camlock to have a locked target
    if mode == "Target" then
        if not lockedTarget then return nil end
        target = lockedTarget
    -- FOV mode: works independently using visual FOV (use cached pos to reduce FPS cost; display path does not use cache)
    elseif mode == "FOV" then
        if not forDisplay then
            local now = tick()
            if now - _fovSilentAimCachePosTime < FOV_SILENT_AIM_CACHE_INTERVAL and _fovSilentAimCachePos then
                return _fovSilentAimCachePos
            end
        end
        target = findSilentAimTarget()
        if not target then if not forDisplay then _fovSilentAimCachePos = nil end return nil end
    else
        return nil
    end
    
    local char = getChar(target)
    if not char then return nil end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return nil end
    if isKnockedOrGrabbed(char) then return nil end
    if hasForceField(char) then return nil end
    if typeof(target) == "Instance" and target:IsA("Player") and isFriend(target) then return nil end
    
    -- Range check for silent aim
    if getConfig() and getConfig().Range and getConfig().Range.Enabled then
        local head = char:FindFirstChild("Head")
        if head then
            local origin = camera.CFrame.Position
            local distance = (head.Position - origin).Magnitude
            if distance > ((getConfig() and getConfig().Range and getConfig().Range.Range) or 1000) then
                return nil
            end
        end
    end
    
    -- Wall check for silent aim (always do fresh check, not cached)
    if getConfig() and getConfig().Checks and getConfig().Checks.WallCheck then
        local head = char:FindFirstChild("Head")
        if not head or not partVisible(head) then
            return nil
        end
    end
    
    -- Get position based on silent aim's own aim mode (and part target when Part mode)
    local saAimMode = (sa and sa.AimMode) or "ClosestPoint"
    local targetPos = nil
    if saAimMode == "ClosestPart" then 
        targetPos = getClosestPartPos(char, true)
    elseif saAimMode == "ClosestPoint" then 
        targetPos = getClosestPointPos(char, true)
    elseif saAimMode == "Part" then 
        local saPartTarget = (sa and sa.PartTarget) or "Head"
        targetPos = getPartPos(char, true, saPartTarget)
    end
    
    -- Anti Curve check: Only apply aim if target is within angular curve threshold
    if targetPos then
        local antiCurveResult = true
        local success, result = pcall(function()
            return checkAntiCurve(targetPos)
        end)
        if success then
            antiCurveResult = result
        end
        if not antiCurveResult then
            return nil -- Target is outside angular curve, don't apply aim
        end
    end
    
    -- HitChance: % of shots that actually get silent aim (rest go where you're aiming = "miss"); skip for display/snapline
    if not forDisplay then
        local hitchance = (sa and sa.HitChance) or 100
        if targetPos and type(hitchance) == "number" then
            local pct = math.clamp(hitchance, 0, 100)
            if math.random(1, 100) > pct then
                return nil
            end
        end
    end

    if not forDisplay and mode == "FOV" and targetPos then
        _fovSilentAimCachePos = targetPos
        _fovSilentAimCachePosTime = tick()
    end
    return targetPos
end

-- Silent Aim snapline: separate RenderStepped so closure sees getSilentAimTargetPos (defined above)
track(RunService.RenderStepped, function()
    if stopped() then return end
    local cfg = getConfig()
    local sa = cfg and cfg.SilentAim
    if not (sa and sa.Enabled and sa.Snapline and sa.Snapline.Enabled) then
        if saSnapline then saSnapline.Visible = false end
        return
    end
    local ok, cursor = pcall(getCursorPos)
    if not ok or not cursor then if saSnapline then saSnapline.Visible = false end return end
    local worldPos = getSilentAimTargetPos(true)
    if not worldPos then if saSnapline then saSnapline.Visible = false end return end
    local scr, onScreen = camera:WorldToViewportPoint(worldPos)
    if not onScreen then if saSnapline then saSnapline.Visible = false end return end
    pcall(function()
        if not Drawing or type(Drawing.new) ~= "function" then return end
        if not saSnapline then saSnapline = Drawing.new("Line") end
        saSnapline.From = cursor
        saSnapline.To = Vector2.new(scr.X, scr.Y)
        saSnapline.Color = sa.Snapline.Color or Color3.new(1,1,1)
        saSnapline.Thickness = sa.Snapline.Thickness or 1
        saSnapline.Transparency = 1
        saSnapline.Visible = true
    end)
end)

-- Current "sync" target: who we're camlocking or who silent aim would shoot (for triggerbot "Only On Camlock Target")
local function getCurrentSyncTarget()
    local aa = getConfig() and getConfig().AimAssist
    local sa = getConfig() and getConfig().SilentAim
    if lockedTarget then
        if aa and aa.Enabled then return lockedTarget end
        if sa and sa.Enabled and (sa.Mode or "Target") == "Target" then return lockedTarget end
    end
    if sa and sa.Enabled and (sa.Mode or "Target") == "FOV" then return findSilentAimTarget() end
    return nil
end

-- Target position for client bullet redirection (uses silent aim pos or aim assist locked target)
local function getBulletRedirectTargetPos()
    local gm = getConfig() and getConfig().GunModifications
    if not gm or not gm.ClientBulletRedirection or not gm.ClientBulletRedirection.Enabled then
        return nil
    end
    local sa = getConfig() and getConfig().SilentAim
    -- FOV mode: only use FOV-based target; never fall back to aim-assist lock (so it stays FOV, not Target)
    if sa and sa.Enabled and (sa.Mode or "Target") == "FOV" then
        return getSilentAimTargetPos()
    end
    return getSilentAimTargetPos() or getLockedTargetPos()
end

-- Anti Aim Viewer: write cursor to remote (Heartbeat+RenderStepped). Add games by PlaceId; entry: remote, parentName (opt), eventArg1.
local ANTI_AIM_VIEWER_WRITE = {
    [105305881594005] = { remote = "MainRemoteEvent", parentName = "MainRemotes", eventArg1 = "DEAHOODMOUSEPOSx3^3" },
    [98343466176190] = { remote = "MainRemoteEvent", parentName = "Remotes", eventArg1 = "Z3eHooDMSOUEPoS233^+" },
    [93778920465645] = { remote = "MainRemoteEvent", parentName = "Remotes", eventArg1 = "NOPEATALL^+", fixedPos = Vector3.new(-101.42888641357422, 37.05597686767578, -776.2234497070312) },
    [129449254792324] = { remote = "MainEvent", eventArg1 = "b8bbd5d73" },
    [122120252103378] = { remote = "MainEvent", eventArg1 = "UpdateMousePos" },
    [110917236678062] = { remote = "MAINEVENT", eventArg1 = "MOUSE" },
    [130879446158509] = { remote = "MAINEVENT", eventArg1 = "MOUSE" },
}
local _cachedAntiAimRemotes = {}
local function getAntiAimWriteRemote(placeId)
    -- Normalize placeId so lookup works (game.PlaceId is number; table key may be number)
    local pid = type(placeId) == "number" and placeId or tonumber(placeId)
    local w = (pid and ANTI_AIM_VIEWER_WRITE[pid]) or ANTI_AIM_VIEWER_WRITE[placeId]
    if not w then return nil end
    local key = tostring(placeId) .. (w.parentName or "") .. w.remote
    if _cachedAntiAimRemotes[key] ~= nil then return _cachedAntiAimRemotes[key] end
    local rs = game:GetService("ReplicatedStorage")
    local parent = w.parentName and rs:FindFirstChild(w.parentName) or rs
    local rem = parent and parent:FindFirstChild(w.remote)
    -- If not found at top level, try common folders (e.g. Remotes, Events) for games that nest MainEvent
    if not rem or not rem:IsA("RemoteEvent") then
        for _, folderName in ipairs({"Remotes", "Events", "Replicated", "Shared"}) do
            local folder = rs:FindFirstChild(folderName)
            if folder then
                rem = folder:FindFirstChild(w.remote)
                if rem and rem:IsA("RemoteEvent") then break end
            end
        end
    end
    if rem and rem:IsA("RemoteEvent") then
        _cachedAntiAimRemotes[key] = rem
        return rem
    end
    return nil
end
