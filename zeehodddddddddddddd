-- Velocity Predictor: Tracks velocity history and predicts future velocity changes
local VelocityHistory = {} -- Stores velocity history for each player
local VelocityPredictorResults = {}

-- Update velocity history every frame
track(RunService.RenderStepped, function()
    local res = getConfig() and getConfig().Resolver
    if stopped() or not (res and res.Enabled) then return end
    
    for _, plr in Players:GetPlayers() do
        if plr == player then continue end
        local char = getChar(plr)
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then
            VelocityHistory[plr.UserId] = nil
            VelocityPredictorResults[plr.UserId] = Vector3.new(0, 0, 0)
            continue
        end
        
        local userId = plr.UserId
        local currentPos = root.Position
        local currentTime = tick()
        
        -- Initialize history if needed
        if not VelocityHistory[userId] then
            VelocityHistory[userId] = {
                positions = {},
                times = {},
                velocities = {}
            }
        end
        
        local history = VelocityHistory[userId]
        
        -- Add current position and time
        table.insert(history.positions, currentPos)
        table.insert(history.times, currentTime)
        
        -- Calculate velocity from position change
        if #history.positions >= 2 then
            local lastPos = history.positions[#history.positions - 1]
            local lastTime = history.times[#history.times - 1]
            local deltaTime = currentTime - lastTime
            
            if deltaTime > 0 and deltaTime < 0.1 then
                local velocity = (currentPos - lastPos) / deltaTime
                table.insert(history.velocities, velocity)
            else
                table.insert(history.velocities, Vector3.new(0, 0, 0))
            end
        else
            table.insert(history.velocities, Vector3.new(0, 0, 0))
        end
        
        -- Keep only recent history (based on HistorySize)
        local historySize = 5
        if #history.positions > historySize then
            table.remove(history.positions, 1)
            table.remove(history.times, 1)
            table.remove(history.velocities, 1)
        end
        
        -- Predict future velocity based on history
        if #history.velocities >= 2 then
            local predictedVel = Vector3.new(0, 0, 0)
            local predictionStrength = 0.8
            
            -- Get current velocity
            local currentVel = history.velocities[#history.velocities]
            
            -- Calculate acceleration (change in velocity)
            if #history.velocities >= 2 then
                local prevVel = history.velocities[#history.velocities - 1]
                local prevTime = history.times[#history.times - 1]
                local currTime = history.times[#history.times]
                local deltaTime = currTime - prevTime
                
                if deltaTime > 0 and deltaTime < 0.1 then
                    local acceleration = (currentVel - prevVel) / deltaTime
                    
                    -- Predict future velocity: currentVel + acceleration * predictionTime
                    -- Use a small prediction time to anticipate direction changes
                    local predictionTime = 0.05 * predictionStrength
                    predictedVel = currentVel + (acceleration * predictionTime)
                    
                    -- If we have more history, use weighted average of accelerations
                    if #history.velocities >= 3 then
                        local avgAcceleration = Vector3.new(0, 0, 0)
                        local weightSum = 0
                        
                        for i = 2, #history.velocities do
                            local vel1 = history.velocities[i - 1]
                            local vel2 = history.velocities[i]
                            local time1 = history.times[i - 1]
                            local time2 = history.times[i]
                            local dt = time2 - time1
                            
                            if dt > 0 and dt < 0.1 then
                                local accel = (vel2 - vel1) / dt
                                local weight = i / #history.velocities -- More recent = higher weight
                                avgAcceleration = avgAcceleration + (accel * weight)
                                weightSum = weightSum + weight
                            end
                        end
                        
                        if weightSum > 0 then
                            avgAcceleration = avgAcceleration / weightSum
                            -- Use weighted combination of current prediction and average acceleration
                            predictedVel = currentVel * 0.4 + (currentVel + avgAcceleration * predictionTime) * 0.6
                        end
                    end
                else
                    predictedVel = currentVel
                end
            else
                predictedVel = currentVel
            end
            
            -- Detect direction changes and predict them (up, down, left, right, forward, backward)
            if #history.velocities >= 3 then
                local sensitivity = 0.3
                
                -- Check for direction changes in each axis
                local vel1 = history.velocities[#history.velocities - 2]
                local vel2 = history.velocities[#history.velocities - 1]
                local vel3 = history.velocities[#history.velocities]
                
                -- Calculate acceleration for each axis
                local accelX = vel3.X - vel2.X
                local accelY = vel3.Y - vel2.Y
                local accelZ = vel3.Z - vel2.Z
                
                -- X axis direction change (left/right)
                if math.sign(vel2.X) ~= math.sign(vel3.X) and math.abs(vel3.X) > sensitivity then
                    -- Direction changed, predict continuation with momentum
                    local momentum = math.abs(vel3.X) * 1.3
                    predictedVel = Vector3.new(math.sign(vel3.X) * momentum, predictedVel.Y, predictedVel.Z)
                elseif math.abs(accelX) > sensitivity * 2 then
                    -- Strong acceleration in X direction, predict continuation
                    predictedVel = Vector3.new(vel3.X + (accelX * 0.5), predictedVel.Y, predictedVel.Z)
                end
                
                -- Y axis direction change (up/down)
                if math.sign(vel2.Y) ~= math.sign(vel3.Y) and math.abs(vel3.Y) > sensitivity then
                    -- Direction changed, predict continuation with momentum
                    local momentum = math.abs(vel3.Y) * 1.3
                    predictedVel = Vector3.new(predictedVel.X, math.sign(vel3.Y) * momentum, predictedVel.Z)
                elseif math.abs(accelY) > sensitivity * 2 then
                    -- Strong acceleration in Y direction, predict continuation
                    predictedVel = Vector3.new(predictedVel.X, vel3.Y + (accelY * 0.5), predictedVel.Z)
                end
                
                -- Z axis direction change (forward/backward)
                if math.sign(vel2.Z) ~= math.sign(vel3.Z) and math.abs(vel3.Z) > sensitivity then
                    -- Direction changed, predict continuation with momentum
                    local momentum = math.abs(vel3.Z) * 1.3
                    predictedVel = Vector3.new(predictedVel.X, predictedVel.Y, math.sign(vel3.Z) * momentum)
                elseif math.abs(accelZ) > sensitivity * 2 then
                    -- Strong acceleration in Z direction, predict continuation
                    predictedVel = Vector3.new(predictedVel.X, predictedVel.Y, vel3.Z + (accelZ * 0.5))
                end
                
                -- Predict direction changes based on acceleration patterns
                local accel1 = vel2 - vel1
                local accel2 = vel3 - vel2
                
                -- If acceleration is increasing in a direction, predict stronger movement
                if accel2.Magnitude > accel1.Magnitude * 1.2 then
                    local accelDir = accel2.Unit
                    -- More aggressive prediction for increasing acceleration
                    predictedVel = predictedVel + (accelDir * accel2.Magnitude * 0.5)
                end
                
                -- Predict sudden velocity changes (anti-aim pattern)
                -- If velocity magnitude changed significantly, predict the new direction
                local vel2Mag = vel2.Magnitude
                local vel3Mag = vel3.Magnitude
                if math.abs(vel3Mag - vel2Mag) > 5 and vel3Mag > 0.1 then
                    -- Velocity changed significantly, predict continuation in new direction
                    local vel3Dir = vel3.Unit
                    local predictedMag = vel3Mag * 1.15 -- Predict slightly faster
                    predictedVel = vel3Dir * predictedMag
                end
            end
            
            VelocityPredictorResults[userId] = predictedVel
        else
            VelocityPredictorResults[userId] = history.velocities[#history.velocities] or Vector3.new(0, 0, 0)
        end
    end
end)

local function VelocityPredictor(target)
    if not target then
