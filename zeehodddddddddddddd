-- No spread modification (scale random spread while keeping it centered so it doesn't curve down)
local old
old = hookfunction(math.random, function(...)
    local args = {...}
    if checkcaller() then
        return old(...)
    end
    local gm = getConfig() and getConfig().GunModifications
    local nospread = gm and gm.NoSpread
    if not (nospread and nospread.Enabled) then
        return old(...)
    end
    local k = math.clamp((nospread.Amount or 0) / 100, 0, 1)
    if k >= 1 then
        return old(...)
    end
    if #args == 0 then
        -- math.random() returns [0, 1); keep centered so (val - 0.5) stays symmetric (no downward bias)
        local r = old()
        return 0.5 + (r - 0.5) * k
    end
    if args[1] == -0.05 and args[2] == 0.05 then
        -- math.random(-0.05, 0.05): symmetric range, scale from center
        local r = old(-0.05, 0.05)
        return r * k
    end
    if #args == 2 and type(args[1]) == "number" and type(args[2]) == "number" then
        -- any math.random(low, high): scale from center to avoid bias
        local low, high = args[1], args[2]
        local mid = (low + high) * 0.5
        local r = old(low, high)
        return mid + (r - mid) * k
    end
    return old(...)
end)

