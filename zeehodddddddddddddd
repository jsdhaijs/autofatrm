    if not (res and res.Enabled) then
        if part.AssemblyLinearVelocity then
            return part.AssemblyLinearVelocity
        end
        return Vector3.new(0, 0, 0)
    end
    
    local targetPlayer = Players:GetPlayerFromCharacter(char)
    if not targetPlayer then
        -- Non-player character
        if part.AssemblyLinearVelocity then
            return part.AssemblyLinearVelocity
        end
        return Vector3.new(0, 0, 0)
    end
    
    -- Use selected resolver type
    local resolverType = res.ResolverType or "Velocity"
    local strength = type(res.Strength) == "number" and math.clamp(res.Strength, 0, 1) or 1
    local rawVel = VelocityPredictor(targetPlayer)
    local resolvedVel
    if resolverType == "Velocity" then
        resolvedVel = rawVel
    elseif resolverType == "AttenuateVelocity" then
        local vel = AttenuateVelocityGet(targetPlayer)
        if vel.Magnitude < 1.5 then vel = rawVel end
        resolvedVel = vel
    elseif resolverType == "BuiltVelocity" then
        resolvedVel = BuiltVelocityGet(targetPlayer)
    elseif resolverType == "MoveDirection" then
        resolvedVel = MoveDirectionResolver(targetPlayer)
    elseif resolverType == "AssemblyLinearVelocity" then
        resolvedVel = AssemblyLinearVelocityResolver(targetPlayer)
    elseif resolverType == "RecalculateVelocity" then
        resolvedVel = RecalculateVelocity(targetPlayer)
    else
        resolvedVel = rawVel
    end
    if strength >= 1 then return resolvedVel end
    if strength <= 0 then return rawVel end
    return rawVel + (resolvedVel - rawVel) * strength
end

