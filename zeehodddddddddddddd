-- Get closest point on part using improved method
local function GetClosestPointOnPart(part, scale)
    if not part or not part:IsA("BasePart") then return nil end
    
    local cf = part.CFrame
    local size = part.Size * (scale / 2)
    
    local ray = mouse.UnitRay
    
    if not ray or not ray.Origin or not ray.Direction then
        return nil
    end
    
    -- Find the point on the ray closest to the part center
    local partCenter = cf.Position
    local rayToPart = partCenter - ray.Origin
    local t = ray.Direction:Dot(rayToPart)
    
    -- Only consider points in front of the camera
    if t < 0 then 
        return nil 
    end
    
    local closestPointOnRay = ray.Origin + (ray.Direction * t)
    
    -- Transform to part's object space
    local rel = cf:PointToObjectSpace(closestPointOnRay)
    
    -- Clamp to the scaled part bounds
    local clamped = Vector3.new(
        math.clamp(rel.X, -size.X, size.X),
        math.clamp(rel.Y, -size.Y, size.Y),
        math.clamp(rel.Z, -size.Z, size.Z)
    )
    
    -- Transform back to world space
    local result = cf:PointToWorldSpace(clamped)
    
    if not result or result.Magnitude > 100000 then
        return nil
    end
    
    return result
end

local function getClosestPointPos(char, skipCachedCheck)
    -- Wall check: use cached if available, otherwise do fresh check
    local wallCheckPassed = true
    if getConfig() and getConfig().Checks and getConfig().Checks.WallCheck then
        if skipCachedCheck or not cachedWallCheck then
            -- Do fresh wall check for silent aim
            local head = char:FindFirstChild("Head")
            if head then
                wallCheckPassed = partVisible(head)
            else
                wallCheckPassed = false
            end
        else
            wallCheckPassed = cachedWallCheck
        end
        if not wallCheckPassed then return nil end
    end
    
    local origin = camera.CFrame.Position
    local ray = mouse.UnitRay
    
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {getOwnChar()}
    params.FilterType = Enum.RaycastFilterType.Blacklist
    
    -- Scale %: turns up the effective points/area on R15 parts for closest point (1-100% -> 0.01-1.0; legacy: v<1 = old scale)
    local sa = getConfig() and getConfig().SilentAim
    local v = (sa and sa.ClosestPointScaleValue) or 12
    local scale = (v < 1) and v or math.clamp(v / 100, 0.01, 1)
    
    if sa and sa.ClosestPointScale == "Generic" then
        -- Generic scale: adaptive based on character distance
        local head = char:FindFirstChild("Head")
        if head then
            local charDist = (head.Position - origin).Magnitude
            -- Scale based on distance (closer = smaller scale, farther = larger scale)
            scale = math.clamp(0.08 + (charDist / 2000), 0.08, 0.2)
        end
    end
    
    -- Find the part whose closest point is actually closest to cursor
    -- First filter by center distance, then find closest point among those
    local bestPart = nil
    local bestClosestPoint = nil
    local bestScreenDistance = math.huge
    
    -- Get mouse position
    local mousePosition = UIS:GetMouseLocation()
    local mouseRay = camera:ViewportPointToRay(mousePosition.X, mousePosition.Y)
    
    -- First, collect parts and their center distances
    local partCandidates = {}
    for _, p in char:GetDescendants() do
        if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
            local scr, on = camera:WorldToViewportPoint(p.Position)
            if scr.Z > 0 then
                local screenPos = Vector2.new(scr.X, scr.Y)
                local centerDist = (screenPos - mousePosition).Magnitude
                table.insert(partCandidates, {part = p, centerDist = centerDist})
            end
        end
    end
    
    -- Sort by center distance (closest centers first)
    table.sort(partCandidates, function(a, b) return a.centerDist < b.centerDist end)
    
    -- Check the top 10 parts by center distance (this ensures leg parts are checked when aiming at legs)
    local maxCheck = math.min(10, #partCandidates)
    for i = 1, maxCheck do
        local data = partCandidates[i]
        local p = data.part
        
        -- Calculate closest point on this part using the configured scale
        local closestPoint = GetClosestPointOnPart(p, scale)
        if closestPoint then
            -- Convert closest point to screen space
            local scrPoint, onPoint = camera:WorldToViewportPoint(closestPoint)
            if scrPoint.Z > 0 then
                local screenPos = Vector2.new(scrPoint.X, scrPoint.Y)
                local screenDist = (screenPos - mousePosition).Magnitude
                
                -- Find the part whose closest point is actually closest to cursor
                if screenDist < bestScreenDistance then
                    bestScreenDistance = screenDist
                    bestPart = p
                    bestClosestPoint = closestPoint
                end
            end
        end
    end
    
    -- Fallback: if no good candidate found, check all parts
    if not bestPart then
        for _, p in char:GetDescendants() do
            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                local scr, on = camera:WorldToViewportPoint(p.Position)
                if scr.Z > 0 then
                    local closestPoint = GetClosestPointOnPart(p, scale)
                    if closestPoint then
                        local scrPoint, onPoint = camera:WorldToViewportPoint(closestPoint)
                        if scrPoint.Z > 0 then
                            local screenPos = Vector2.new(scrPoint.X, scrPoint.Y)
                            local screenDist = (screenPos - mousePosition).Magnitude
                            
                            if screenDist < bestScreenDistance then
                                bestScreenDistance = screenDist
                                bestPart = p
                                bestClosestPoint = closestPoint
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- Fallback to head if no part found
    if not bestPart then
        bestPart = char:FindFirstChild("Head")
        if bestPart then
            bestClosestPoint = GetClosestPointOnPart(bestPart, scale)
        end
    end
    
    -- Fallback to HumanoidRootPart if still no part found
    if not bestPart then
        bestPart = char:FindFirstChild("HumanoidRootPart")
        if bestPart then
            bestClosestPoint = GetClosestPointOnPart(bestPart, scale)
        end
    end
    
    if not bestPart or not bestClosestPoint then
        -- Ultimate fallback to closest part method
        return getClosestPartPos(char, skipCachedCheck)
    end
    
    -- Use the closest point we found
    local closestPoint = bestClosestPoint
    if not closestPoint then
        return getClosestPartPos(char, skipCachedCheck)
    end
    
    -- Apply prediction
    local finalPos
    if skipCachedCheck then
        local distance = (closestPoint - origin).Magnitude
        finalPos = predictSilentAim(closestPoint, bestPart, char, distance)
    else
        local predictionValue = getPredictionValue()
        finalPos = predict(closestPoint, bestPart, predictionValue)
    end
    
    return finalPos
end

