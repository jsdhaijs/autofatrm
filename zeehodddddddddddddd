-- triggerbot
local function click()
    mouse1press()
    task.wait(0.01)
    mouse1release()
end

local function startTriggerbot()
    if triggerConn then triggerConn:Disconnect() end
    triggerConn = track(RunService.Heartbeat, function()
        local cfg = getConfig()
        if not cfg or not cfg.Triggerbot or not cfg.Triggerbot.Enabled then
            if triggerEnabled then disableTriggerbot() end
            return
        end
        -- Hold mode: only active while key is held; check every frame so release is detected reliably
        local activationMode = (cfg.Triggerbot.Mode) or "Toggle"
        if activationMode == "Hold" then
            local ok, keyDown = pcall(function() return UserInputService:IsKeyDown(getTriggerKey()) end)
            if not (ok and keyDown) then
                if triggerEnabled then disableTriggerbot() end
                return
            end
        end
        if stopped() or not triggerEnabled or isBlacklistedItemEquipped() then return end
        if isChatFocused() then return end
        local now = tick()
        local delayMs = tonumber(flags and flags.tb_delay) or tonumber(cfg.Triggerbot and cfg.Triggerbot.TriggerDelay) or 0
        local delaySec = (delayMs and delayMs > 0) and (delayMs / 1000) or 0
        if delaySec > 0 and (now - lastFireTime) < delaySec then return end
        
        local origin = camera.CFrame.Position
        local ray = mouse.UnitRay
        local params = RaycastParams.new()
        params.FilterDescendantsInstances = {getOwnChar()}
        params.FilterType = Enum.RaycastFilterType.Blacklist
        
        local res = workspace:Raycast(origin, ray.Direction * 1000, params)
        if not res then return end
        
        local hitPart = res.Instance
        local hitChar = hitPart:FindFirstAncestorWhichIsA("Model")
        if not hitChar then return end
        
        local hitPlr = Players:GetPlayerFromCharacter(hitChar)
        local isBot = isBotTarget(hitChar)
        if not hitPlr and not isBot then return end
        if hitPlr and hitPlr == player then return end
        
        if hitPlr then
            if not isAlive(hitPlr) or isKnockedOrGrabbed(hitChar) then return end
            if hasForceField(hitChar) then return end
            if isFriend(hitPlr) then return end
        else
            if not hitChar:FindFirstChild("Humanoid") or hitChar.Humanoid.Health <= 0 then return end
            if hasForceField(hitChar) then return end
        end
        
        if getConfig() and getConfig().Range and getConfig().Range.Enabled then
            local head = hitChar:FindFirstChild("Head")
            local checkPart = head or hitPart
            local distance = (checkPart.Position - origin).Magnitude
            if distance > ((getConfig() and getConfig().Range and getConfig().Range.Range) or 1000) then return end
        end
        
        if cfg.Triggerbot.TriggerWallCheck and not partVisible(hitPart) then return end
        
        if cfg.Triggerbot.FOV and cfg.Triggerbot.FOV.Enabled then
            local head = hitChar:FindFirstChild("Head")
            local checkPart = head or hitPart
            local scr, onScreen = camera:WorldToViewportPoint(checkPart.Position)
            if scr.Z > 0 then
                local cursor = getCursorPos()
                local screenPos = Vector2.new(scr.X, scr.Y)
                local fovSize = (cfg.Triggerbot.FOV.Size or 180)
                if (screenPos - cursor).Magnitude > fovSize then return end
            else
                return
            end
        end
        
        if cfg.Triggerbot.OnlyOnCamlockTarget then
            local syncTgt = getCurrentSyncTarget()
            if not syncTgt then return end
            if getChar(syncTgt) ~= hitChar then return end
        end
        
        local predictedPos = predict(hitPart.Position, hitPart, getTriggerPredictionValue())
        local dirToPredicted = (predictedPos - origin).Unit
        local alignment = ray.Direction:Dot(dirToPredicted)
        
        if alignment > 0.85 then
            lastFireTime = now
            local humanizationMs = (cfg.Triggerbot.HumanizationDelay and type(cfg.Triggerbot.HumanizationDelay) == "number") and cfg.Triggerbot.HumanizationDelay or 0
            if humanizationMs > 0 then
                task.spawn(function()
                    task.wait(math.random() * humanizationMs / 1000)
                    click()
                end)
            else
                click()
            end
        end
    end)
end

-- Enable/Disable functions
local function enableAimbot()
    if aimEnabled then return end
    if not getConfig() or not getConfig().AimAssist or not getConfig().AimAssist.Enabled then return end
    local aa = getConfig() and getConfig().AimAssist
    local activationMode = (aa and aa.Mode) or "Toggle"
    local tgt = findClosestTarget()
    -- Hold mode: enable and start loop even without target (we'll acquire each frame). Toggle: need target to enable.
    if not tgt and activationMode ~= "Hold" then return end
    if tgt then
        lockedTarget = tgt
        local res = getConfig() and getConfig().Resolver
        if res and res.Enabled and res.ResolverType == "AttenuateVelocity" then
            AttenuateVelocityResolver.Assign(tgt)
        end
    end
    aimEnabled = true
    cachedWallCheck = true
    lastWallCheck = 0 -- Reset wall check timer
    
    local mode = (aa and aa.Method) or "Camlock"
    if mode == "Mouse" then
        mouseConn = track(RunService.Heartbeat, updateMouse)
    else -- Default to Camlock
