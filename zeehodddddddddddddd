-- AttenuateVelocity Resolver
local AttenuateVelocityResolver = {}
local _noiseScale = 0.1
local _sensorNoise = 0.1
local _fadeRate = 0.5
local _subject = nil
local _attenuateStore = {}

function AttenuateVelocityResolver.Assign(targetPlayer)
    if targetPlayer then
        local char = getChar(targetPlayer)
        _subject = char
        if not _attenuateStore[targetPlayer.UserId] then
            _attenuateStore[targetPlayer.UserId] = {
                Pos = Vector3.zero,
                Vel = Vector3.zero,
                Acc = Vector3.zero,
                Confidence = 1
            }
        end
    else
        _subject = nil
    end
end

local function _predictor(dt, now, lastPos, lastVel, lastAcc, userId)
    local store = _attenuateStore[userId]
    if not store then return Vector3.zero, Vector3.zero end
    
    local velNow = (now - lastPos) / dt
    local guessPos = lastPos + store.Vel * dt
    local guessVel = lastVel
    
    local confidence = store.Confidence or 1
    local blend = confidence / (confidence + _sensorNoise)
    
    local fixPos = guessPos + blend * (now - guessPos)
    local fixVel = guessVel + blend * (velNow - guessVel)
    store.Confidence = (1 - blend) * confidence + _noiseScale
    
    local fade = _fadeRate / (_fadeRate + dt)
    local smoothVel = store.Vel + fade * (fixVel - store.Vel)
    local smoothAcc = fade * store.Acc + (1 - fade) * (smoothVel - store.Vel) / dt
    
    return smoothVel, smoothAcc
end

function AttenuateVelocityResolver.Track(dt, focus, userId)
    if not (dt and dt > 1e-6) then return Vector3.zero end
    if focus and focus:FindFirstChild("HumanoidRootPart") then
        local store = _attenuateStore[userId]
        if not store then
            _attenuateStore[userId] = {
                Pos = Vector3.zero,
                Vel = Vector3.zero,
                Acc = Vector3.zero,
                Confidence = 1
            }
            store = _attenuateStore[userId]
        end
        
        local current = focus.HumanoidRootPart.Position
        local v, a = _predictor(dt, current, store.Pos, store.Vel, store.Acc, userId)
        store.Pos = current
        store.Vel = v
        store.Acc = a
        return v
    end
    return Vector3.zero
end

