-- RecalculateVelocity Resolver
local recalculateVelocityPrevious = {}

local function RecalculateVelocity(target)
    local char = target.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not root then
        return Vector3.zero
    end
    
    local currentPos = root.Position
    local currentTime = tick()
    local previous = recalculateVelocityPrevious[target.UserId]
    
    if previous and previous.time then
        local deltaTime = currentTime - previous.time
        if deltaTime > 0 then
            local velocity = (currentPos - previous.position) / deltaTime
            recalculateVelocityPrevious[target.UserId] = {
                position = currentPos,
                time = currentTime
            }
            return velocity
        end
    end
    
    recalculateVelocityPrevious[target.UserId] = {
        position = currentPos,
        time = currentTime
    }
    
    return Vector3.zero
end

