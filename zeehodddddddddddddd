        local predictionValue = getPredictionValue()
        return predict(targetPart.Position, targetPart, predictionValue)
    end
end

-- optimized wall check with throttling
local function quickWallCheck(char)
    if not getConfig() or not getConfig().Checks or not getConfig().Checks.WallCheck then return true end
    local now = tick()
    -- Automatic throttle: 0.1 seconds between wall checks to reduce lag
    if now - lastWallCheck < 0.1 then
        return cachedWallCheck
    end
    lastWallCheck = now
    local head = char:FindFirstChild("Head")
    if not head then 
        cachedWallCheck = false
        return false
    end
    cachedWallCheck = partVisible(head)
    return cachedWallCheck
end

-- target selection
local function getLockedTargetPos()
    if not lockedTarget then return nil end
    local char = getChar(lockedTarget)
    local res = getConfig() and getConfig().Resolver
    if not char or not isAlive(lockedTarget) or isKnockedOrGrabbed(char) then
        lockedTarget = nil
        if res and res.Enabled and res.ResolverType == "AttenuateVelocity" then
            AttenuateVelocityResolver.Assign(nil)
        end
        cachedWallCheck = true
        return nil
    end
    if hasForceField(char) then
        lockedTarget = nil
        if res and res.Enabled and res.ResolverType == "AttenuateVelocity" then
            AttenuateVelocityResolver.Assign(nil)
        end
        cachedWallCheck = true
        return nil
    end
    if isFriend(lockedTarget) then
        lockedTarget = nil
        if res and res.Enabled and res.ResolverType == "AttenuateVelocity" then
            AttenuateVelocityResolver.Assign(nil)
        end
        cachedWallCheck = true
        return nil
    end
    
    -- Range check - pause tracking if target goes out of range, but keep lock
    if getConfig() and getConfig().Range and getConfig().Range.Enabled then
        local head = char:FindFirstChild("Head")
        if head then
            local origin = camera.CFrame.Position
            local distance = (head.Position - origin).Magnitude
            if distance > ((getConfig() and getConfig().Range and getConfig().Range.Range) or 1000) then
                -- Target is out of range - pause tracking but keep lock
                -- This allows automatic re-locking when target comes back in range
                return nil
            end
        end
    end
    
    -- Quick wall check with throttling to prevent lag
    local isVisible = quickWallCheck(char)
    local ch = (getConfig() or {}).Checks
    if not isVisible then
        -- Behind wall: only unlock if UnlockOnWall is on; otherwise keep lock and resume when visible
        if ch and ch.UnlockOnWall then
            lockedTarget = nil
            if res and res.Enabled and res.ResolverType == "AttenuateVelocity" then
                AttenuateVelocityResolver.Assign(nil)
            end
            cachedWallCheck = true
        end
        return nil
    end
    
    -- Only do expensive calculations if wall check passes
    local aa = getConfig() and getConfig().AimAssist
    local targetPos = nil
    if aa and aa.AimMode == "ClosestPart" then 
        targetPos = getClosestPartPos(char)
    elseif aa and aa.AimMode == "ClosestPoint" then 
        targetPos = getClosestPointPos(char)
    elseif aa and aa.AimMode == "Part" then 
        targetPos = getPartPos(char)
    end
    
    -- Apply aimbot vertical offset when enabled: jump offset when target is in air, normal offset when on ground
    if targetPos and aa and aa.UseOffsets then
        local humanoid = char:FindFirstChild("Humanoid")
        local offset = (humanoid and humanoid.FloorMaterial == Enum.Material.Air) and (aa.JumpOffset or 0) or (aa.NormalOffset or 0)
        targetPos = targetPos + Vector3.new(0, offset, 0)
    end
    
    return targetPos
end

-- Get visual FOV size
local function getVisualFOV()
    local v = getConfig() and getConfig().Visuals and getConfig().Visuals.FOV
    return (v and v.Size) or 180
end

-- Get maximum visual FOV value (for threshold comparisons)
local function getMaxVisualFOV()
    local v = getConfig() and getConfig().Visuals and getConfig().Visuals.FOV
    return (v and v.Size) or 180
end

local function findClosestTarget()
    local priority = (getConfig() and getConfig().AimAssist and getConfig().AimAssist.TargetPriority) or "Closest to crosshair"
    local cursor = getCursorPos()
    local origin = camera.CFrame.Position
    local maxFov = getMaxVisualFOV()
    local candidates = {}
    
    for _,target in getAllTargets() do
        local char = getChar(target)
        if not char then continue end
        
        local humanoid = char:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        if isKnockedOrGrabbed(char) then continue end
        if hasForceField(char) then continue end
        if typeof(target) == "Instance" and target:IsA("Player") and isFriend(target) then continue end
        
        local head = char:FindFirstChild("Head")
        local checks = (getConfig() or {}).Checks
        if not head or (checks and checks.WallCheck and not partVisible(head)) then continue end
        
        if getConfig() and getConfig().Range and getConfig().Range.Enabled then
            local dist = (head.Position - origin).Magnitude
            if dist > ((getConfig() and getConfig().Range and getConfig().Range.Range) or 1000) then continue end
        end
        
        local scr,on = camera:WorldToViewportPoint(head.Position)
        if not on then continue end
        local cursorDist = (Vector2.new(scr.X,scr.Y) - cursor).Magnitude
        if cursorDist >= maxFov then continue end
        
        local distToCam = (head.Position - origin).Magnitude
        candidates[#candidates + 1] = { target = target, cursorDist = cursorDist, health = humanoid.Health, distance = distToCam }
    end
    if #candidates == 0 then return nil end
    if priority == "Closest to crosshair" then
        table.sort(candidates, function(a,b) return a.cursorDist < b.cursorDist end)
    elseif priority == "Lowest HP" then
        table.sort(candidates, function(a,b) return a.health < b.health end)
    else
        table.sort(candidates, function(a,b) return a.distance < b.distance end)
    end
    return candidates[1].target
end

