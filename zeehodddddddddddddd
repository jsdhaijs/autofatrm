-- Anti Aim Viewer (global function to avoid "exceeded limit 200" locals in parent)
function initAntiAimViewer(writeTable, getRemoteFunc, cacheTable, placeIdBox)
    local ANTI_AIM_VIEWER_THROTTLE = 0.05
    local _lastAntiAimFireTime = 0
    local function fireAntiAimCursorToRemote()
        if stopped() or not getConfig() or not getConfig().SilentAim or not getConfig().SilentAim.AntiAimViewer then return end
        local placeId = game.PlaceId
        if placeIdBox[1] ~= nil and placeIdBox[1] ~= placeId then
            for k in pairs(cacheTable) do cacheTable[k] = nil end
        end
        placeIdBox[1] = placeId
        local writeEntry = writeTable[placeId]
        if not writeEntry then return end
        local rem = getRemoteFunc(placeId)
        if not rem then return end
        local now = tick()
        if now - _lastAntiAimFireTime < ANTI_AIM_VIEWER_THROTTLE then return end
        _lastAntiAimFireTime = now
        local cam = workspace.CurrentCamera
        local cursorPos = cam and (function()
            local ml = uis:GetMouseLocation()
            local r = cam:ViewportPointToRay(ml.X, ml.Y)
            local params = RaycastParams.new()
            params.FilterDescendantsInstances = lp.Character and {lp.Character} or {}
            params.FilterType = Enum.RaycastFilterType.Exclude
            local hit = workspace:Raycast(r.Origin, r.Direction * 10000, params)
            return hit and hit.Position or (r.Origin + r.Direction * 500)
        end)() or Vector3.zero
        local pos = writeEntry.fixedPos or cursorPos
        if pos ~= Vector3.zero then
            pcall(function() rem:FireServer(writeEntry.eventArg1, pos) end)
        end
    end
    track(RunService.Heartbeat, fireAntiAimCursorToRemote)
    track(RunService.Heartbeat, function()
        if stopped() then return end
        local cfg = getConfig()
        if not cfg or not cfg.SilentAim or not cfg.SilentAim.AntiAimViewer then return end
        local playersFolder = workspace:FindFirstChild("Players")
        if not playersFolder then return end
        local playerModel = playersFolder:FindFirstChild(lp.Name)
        if not playerModel then return end
        local be = playerModel:FindFirstChild("BodyEffects")
        if not be then return end
        local mousePosVal = be:FindFirstChild("MousePos")
        if mousePosVal and mousePosVal:IsA("Vector3Value") then
            pcall(function()
                local cam = workspace.CurrentCamera
                if cam then
                    local ml = uis:GetMouseLocation()
                    local r = cam:ViewportPointToRay(ml.X, ml.Y)
                    local params = RaycastParams.new()
                    params.FilterDescendantsInstances = lp.Character and {lp.Character} or {}
                    params.FilterType = Enum.RaycastFilterType.Exclude
                    local hit = workspace:Raycast(r.Origin, r.Direction * 10000, params)
                    mousePosVal.Value = hit and hit.Position or (r.Origin + r.Direction * 500)
                end
            end)
        end
    end)
end
-- Pass anonymous table to avoid adding a local (hits "exceeded limit 200" registers in this scope)
