local lastMovementEnabled = false -- Detect when user enables checkbox so we don't require keybind
local originalWalkSpeed = nil -- Will be set when character loads
local originalJumpPower = nil -- Will be set when character loads
local movementConn = nil
local movementInitialized = false

local function getMovementConfig()
    local cfg = (library and library.astral_config) or Config
    return cfg and cfg.Movement
end

local function initializeOriginalMovement()
    if movementInitialized then return end
    local char = getOwnChar()
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        -- Only store if we haven't stored yet
        if not originalWalkSpeed then
            originalWalkSpeed = humanoid.WalkSpeed
        end
        if not originalJumpPower then
            originalJumpPower = humanoid.JumpPower
            movementInitialized = true
        end
    end
end

local DEFAULT_WALKSPEED = 16
local DEFAULT_JUMPPOWER = 50

local function restoreMovementToOriginal()
    local char = getOwnChar()
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    -- Always restore when feature is off: use captured original or game default so sprint/normal movement works
    local ws = (type(originalWalkSpeed) == "number" and originalWalkSpeed >= 0) and originalWalkSpeed or DEFAULT_WALKSPEED
    humanoid.WalkSpeed = ws
    local jp = (type(originalJumpPower) == "number" and originalJumpPower >= 0) and originalJumpPower or DEFAULT_JUMPPOWER
    pcall(function() if humanoid.JumpPower then humanoid.JumpPower = jp end end)
    pcall(function() if humanoid.JumpHeight then humanoid.JumpHeight = jp / 10 end end)
end

local function setupMovement()
    local Movement = getMovementConfig()
    if not Movement or not Movement.Enabled then
        movementToggled = false
        restoreMovementToOriginal()
        return
    end
end

local function toggleMovement()
    local Movement = getMovementConfig()
    if not Movement or not Movement.Enabled then return end
    
    -- Initialize original movement values if needed
    initializeOriginalMovement()
    
    -- Toggle the state
    movementToggled = not movementToggled
    
    -- Immediately apply the new state (RenderStepped will maintain it when toggled on)
    local char = getOwnChar()
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    if movementToggled then
        local st = Movement.SpeedType or "WalkSpeed"
        local isVelocity = (st == "CFrame" or st == "Velocity")
        if isVelocity then
            humanoid.WalkSpeed = 0
        else
            local ws = Movement.WalkSpeed
            humanoid.WalkSpeed = (type(ws) == "number" and ws >= 0) and ws or 16
            pcall(function() if humanoid.JumpPower then humanoid.JumpPower = Movement.JumpPower or 50 end end)
            pcall(function() if humanoid.JumpHeight then humanoid.JumpHeight = (Movement.JumpPower or 50) / 10 end end)
        end
    else
        -- Restore original values when toggled off (so sprint works again)
        local ws = (type(originalWalkSpeed) == "number" and originalWalkSpeed >= 0) and originalWalkSpeed or DEFAULT_WALKSPEED
        humanoid.WalkSpeed = ws
        local jp = (type(originalJumpPower) == "number" and originalJumpPower >= 0) and originalJumpPower or DEFAULT_JUMPPOWER
        pcall(function() if humanoid.JumpPower then humanoid.JumpPower = jp end end)
        pcall(function() if humanoid.JumpHeight then humanoid.JumpHeight = jp / 10 end end)
    end
end

