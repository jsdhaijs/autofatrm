function library:animation(text)
	local pattern = {}
	for i = 1, tonumber(text:len()) do
		table.insert(pattern, string.sub(text, 1, i))
	end
	for i = tonumber(text:len()) - 1, 0, -1 do
		table.insert(pattern, string.sub(text, 1, i))
	end
	return pattern
end

function library:convert_enum(enum)
	local enum_parts = {}

	for part in string.gmatch(enum, "[%w_]+") do
		table.insert(enum_parts, part)
	end

	local enum_table = Enum
	for i = 2, #enum_parts do
		local enum_item = enum_table[enum_parts[i]]

		enum_table = enum_item
	end

	return enum_table
end

function library:config_list_update()
	if not library.config_holder then return end
	pcall(function()
		if makefolder then
			makefolder(library.directory)
			makefolder(library.directory .. "/configs")
		end
	end)
	local list = {}
	pcall(function()
		if not listfiles then return end
		local dir = library.directory .. "/configs"
		local files = listfiles(dir)
		if type(files) == "table" then
			for _, file in next, files do
				local name = (type(file) == "string" and file:match("([^/\\]+)%.cfg$") or file:match("configs[^/]*/([^/\\]+)%.cfg$")) or file
				if name and name ~= "" then list[#list + 1] = name end
			end
		end
	end)
	library.config_holder:refresh_options(list)
end

local function serialize_astral(t)
	if t == nil then return nil end
	if type(t) == "table" then
		local out = {}
		for k, v in pairs(t) do
			out[k] = serialize_astral(v)
		end
		return out
	end
	local ok, hex = pcall(function()
		if (type(t) == "userdata" or type(t) == "table") and t.ToHex then
			return t:ToHex()
		end
	end)
	if ok and hex and type(hex) == "string" then return hex end
	return t
end

local function apply_astral(dest, src)
	if type(src) ~= "table" then return end
	for k, v in pairs(src) do
		if type(v) == "table" then
			if type(dest[k]) ~= "table" then dest[k] = {} end
			apply_astral(dest[k], v)
		elseif type(v) == "string" and v:match("^%x%x%x%x%x%x$") then
			pcall(function() dest[k] = Color3.fromHex(v) end)
		else
			dest[k] = v
		end
	end
end

function library:get_config()
	local Flags = {}
	for k, v in pairs(flags) do
		if type(v) == "table" and v.key then
			Flags[k] = { active = v.active, mode = v.mode, key = tostring(v.key) }
		elseif type(v) == "table" and v["Transparency"] and v["Color"] then
			Flags[k] = { Transparency = v["Transparency"], Color = (type(v["Color"]) == "userdata" and v["Color"].ToHex and v["Color"]:ToHex()) or v["Color"] }
		else
			Flags[k] = v
		end
	end
	local astral_ser = (library.astral_config and serialize_astral(library.astral_config)) or {}
	return http_service:JSONEncode({ flags = Flags, astral = astral_ser })
end

function library:load_config(config_json)
	local ok, data = pcall(function() return http_service:JSONDecode(config_json) end)
	if not ok or not data then return end
	local config = data.flags or data
	for k, v in pairs(config) do
		local function_set = library.config_flags[k]
		if function_set then
			if type(v) == "table" and v["Transparency"] and v["Color"] then
				pcall(function() function_set(hex(v["Color"]), v["Transparency"]) end)
			elseif type(v) == "table" and v["active"] ~= nil then
				pcall(function() function_set(v) end)
			else
				pcall(function() function_set(v) end)
			end
		end
	end
	if data.astral and library.astral_config then
		pcall(function() apply_astral(library.astral_config, data.astral) end)
	end
end

function library:round(number, float)
	local multiplier = 1 / (float or 1)
	return math.floor(number * multiplier + 0.5) / multiplier
end

function library:apply_theme(instance, theme, property)
	local util = themes.utility and themes.utility[theme]
	if not util or type(util) ~= "table" then return end
	if not util[property] then util[property] = {} end
	table.insert(util[property], instance)
end

local color_to_transparency_prop = {
	BackgroundColor3 = "BackgroundTransparency",
	TextColor3 = "TextTransparency",
	ImageColor3 = "ImageTransparency",
}

function library:update_theme(theme, color, alpha)
	if not theme or type(theme) ~= "string" then return end
	if alpha ~= nil then
		themes.preset_alpha = themes.preset_alpha or {}
		themes.preset_alpha[theme] = alpha
	end
	local old_preset = themes.preset and themes.preset[theme]
	local util = themes.utility and themes.utility[theme]
	-- only update color; do not apply colorpicker alpha to theme elements (avoids overwriting glow/text stroke transparency)
	if type(util) == "table" then
		for prop_name, prop_table in pairs(util) do
			if type(prop_table) == "table" then
				for _, object in pairs(prop_table) do
					if object and object[prop_name] ~= nil then
						if object[prop_name] == old_preset or (object.ClassName == "UIGradient") then
							object[prop_name] = color
						end
					end
				end
			end
		end
	end
	if themes.preset then
		themes.preset[theme] = color
	end
end

