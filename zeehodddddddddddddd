-- One persistent Heartbeat connection for movement
movementConn = track(RunService.Heartbeat, function(dt)
    if stopped() then return end
    local Movement = getMovementConfig()
    if not Movement then restoreMovementToOriginal() return end
    local enabled = Movement.Enabled == true
    if not enabled then
        if lastMovementEnabled then
            movementToggled = false
            restoreMovementToOriginal()
        end
        lastMovementEnabled = false
        return
    end
    -- When user enables Movement checkbox, turn on immediately (no keybind needed)
    if enabled and not lastMovementEnabled then movementToggled = true end
    lastMovementEnabled = true
    if not movementToggled then return end
    local char = getOwnChar()
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    local myRoot = char:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    local speedType = Movement.SpeedType or "WalkSpeed"
    local multiplier = Movement.CFrameSpeed or 200
    if speedType == "CFrame" then
        -- Use original JumpPower so jump isn't boosted (Movement.JumpPower is for Walkspeed mode only)
        local jp = (type(originalJumpPower) == "number" and originalJumpPower >= 0) and originalJumpPower or DEFAULT_JUMPPOWER
        pcall(function() if humanoid.JumpPower then humanoid.JumpPower = jp end end)
        pcall(function() if humanoid.JumpHeight then humanoid.JumpHeight = jp / 10 end end)
        -- WalkSpeed so game sets MoveDirection; give horizontal velocity so run/walk animations play
        humanoid.WalkSpeed = 16
        local moveDir = humanoid.MoveDirection
        local flat = Vector3.new(moveDir.X, 0, moveDir.Z)
        local vy = myRoot.Velocity.Y
        if myRoot.AssemblyLinearVelocity then vy = myRoot.AssemblyLinearVelocity.Y end
        local animSpeed = 16
        if flat.Magnitude > 0.01 then
            local u = flat.Unit
            -- Set velocity so animator sees movement and plays run/walk
            myRoot.Velocity = Vector3.new(u.X * animSpeed, vy, u.Z * animSpeed)
            if myRoot.AssemblyLinearVelocity then
                myRoot.AssemblyLinearVelocity = Vector3.new(u.X * animSpeed, vy, u.Z * animSpeed)
            end
            -- CFrame move: (multiplier - animSpeed) so total speed = multiplier (we don't double-move)
            local cfSpeed = math.max(0, multiplier - animSpeed)
            myRoot.CFrame = myRoot.CFrame + (u * dt * cfSpeed)
        else
            myRoot.Velocity = Vector3.new(0, vy, 0)
            if myRoot.AssemblyLinearVelocity then
                myRoot.AssemblyLinearVelocity = Vector3.new(0, vy, 0)
            end
        end
    elseif speedType == "Velocity" then
        humanoid.WalkSpeed = 16
        local speed = multiplier
        local cam = camera.CFrame
        local lookFlat = Vector3.new(cam.LookVector.X, 0, cam.LookVector.Z)
        local rightFlat = Vector3.new(cam.RightVector.X, 0, cam.RightVector.Z)
        if lookFlat.Magnitude > 0.01 then lookFlat = lookFlat.Unit else lookFlat = cam.LookVector end
        if rightFlat.Magnitude > 0.01 then rightFlat = rightFlat.Unit else rightFlat = cam.RightVector end
        local move = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + lookFlat end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - lookFlat end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + rightFlat end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - rightFlat end
        local moveDir = move.Magnitude > 0.01 and move.Unit or nil
        task.defer(function()
            if not char.Parent or not myRoot.Parent or not humanoid.Parent then return end
            local vyy = myRoot.Velocity.Y
            if myRoot.AssemblyLinearVelocity then vyy = myRoot.AssemblyLinearVelocity.Y end
            if moveDir then
                local vel = moveDir * speed
                myRoot.Velocity = Vector3.new(vel.X, vyy, vel.Z)
                if myRoot.AssemblyLinearVelocity then myRoot.AssemblyLinearVelocity = Vector3.new(vel.X, vyy, vel.Z) end
                pcall(function() humanoid.MoveDirection = moveDir end)
            else
                myRoot.Velocity = Vector3.new(0, vyy, 0)
                if myRoot.AssemblyLinearVelocity then myRoot.AssemblyLinearVelocity = Vector3.new(0, vyy, 0) end
                pcall(function() humanoid.MoveDirection = Vector3.zero end)
            end
        end)
    else
        local ws = Movement.WalkSpeed
        if type(ws) == "number" and ws >= 0 then
            humanoid.WalkSpeed = ws
        else
            humanoid.WalkSpeed = 16
        end
        pcall(function()
            if humanoid.JumpPower then humanoid.JumpPower = Movement.JumpPower or 50 end
        end)
        pcall(function()
            if humanoid.JumpHeight then humanoid.JumpHeight = (Movement.JumpPower or 50) / 10 end
        end)
    end
end)

