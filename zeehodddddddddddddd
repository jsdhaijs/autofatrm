-- Anti Sit (global function to avoid using a local register and hitting "exceeded limit 200")
function initAntiSit()
    local antiSitConnections = {}
    local seatDisableConnection = nil

    local function disableSeat(seat)
        if not seat then return end
        if seat:IsA("Seat") or seat:IsA("VehicleSeat") then
            seat.Disabled = true
            seat:SetAttribute("Neutralized", true)
        end
    end

    local function enableSeat(seat)
        if not seat then return end
        if seat:IsA("Seat") or seat:IsA("VehicleSeat") then
            if seat:GetAttribute("Neutralized") then
                seat.Disabled = false
                seat:SetAttribute("Neutralized", nil)
            end
        end
    end

    local function setupAntiSit(char)
        if not char then return end
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid then
            humanoid = char:WaitForChild("Humanoid", 5)
            if not humanoid then return end
        end
        if antiSitConnections[char] then
            for _, conn in pairs(antiSitConnections[char]) do
                if conn then conn:Disconnect() end
            end
            antiSitConnections[char] = nil
        end
        antiSitConnections[char] = {}
        if humanoid.Sit then humanoid.Sit = false end
        local sitChangedConn = humanoid:GetPropertyChangedSignal("Sit"):Connect(function()
            if Config.Misc.AntiSit and humanoid.Sit then humanoid.Sit = false end
        end)
        table.insert(antiSitConnections[char], sitChangedConn)
        local parentChangedConn = char:GetPropertyChangedSignal("Parent"):Connect(function()
            if not char.Parent then
                if antiSitConnections[char] then
                    for _, conn in pairs(antiSitConnections[char]) do
                        if conn then conn:Disconnect() end
                    end
                    antiSitConnections[char] = nil
                end
            end
        end)
        table.insert(antiSitConnections[char], parentChangedConn)
    end

    local function disableAllSeats()
        for _, obj in pairs(Workspace:GetDescendants()) do
            if Config.Misc.AntiSit then disableSeat(obj) end
        end
    end

    local function setupSeatMonitoring()
        if seatDisableConnection then
            seatDisableConnection:Disconnect()
            seatDisableConnection = nil
        end
        if Config.Misc.AntiSit then
            seatDisableConnection = Workspace.DescendantAdded:Connect(function(obj)
                if obj:IsA("Seat") or obj:IsA("VehicleSeat") then
                    task.wait(0.1)
                    if Config.Misc.AntiSit then disableSeat(obj) end
                end
            end)
        end
    end

    if Config.Misc.AntiSit then
        disableAllSeats()
        setupSeatMonitoring()
        if player.Character then setupAntiSit(player.Character) end
        track(player.CharacterAdded, function(char)
            if stopped() then return end
            setupAntiSit(char)
        end)
    end

    track(RunService.Heartbeat, function()
        if stopped() then return end
        local shouldBeActive = Config.Misc.AntiSit
        local isMonitoring = seatDisableConnection ~= nil
        if shouldBeActive and not isMonitoring then
            disableAllSeats()
            setupSeatMonitoring()
            local char = player.Character
            if char and not antiSitConnections[char] then setupAntiSit(char) end
        elseif not shouldBeActive and isMonitoring then
            if seatDisableConnection then
                seatDisableConnection:Disconnect()
                seatDisableConnection = nil
            end
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("Seat") or obj:IsA("VehicleSeat") then
                    if obj:GetAttribute("Neutralized") then enableSeat(obj) end
                end
            end
        end
    end)
end
initAntiSit()

-- Replacement: Working Gun Chams (only modifies the tool you're holding)
function initGunChams()
    local OGGunProps = {}
    
    local function GetTool()
        local char = player.Character
        if not char then return nil end
        for _, v in pairs(char:GetChildren()) do
            if v:IsA('Tool') and (v:FindFirstChild('Ammo') or v:FindFirstChild('Handle')) then
                return v
            end
        end
        return nil
    end
    
    track(RunService.RenderStepped, function()
        if stopped() then return end
        
        local char = player.Character
        if not char then return end
        
        local Gun = GetTool()
        local cfg = getConfig() and getConfig().Visuals and getConfig().Visuals.SelfCharacter
        
        if not cfg then return end
        
        local useChams = cfg.ToolEnabled
        local enabled = cfg.ToolEnabled
        
        if useChams and enabled and Gun then
            for _, v in pairs(Gun:GetDescendants()) do
                if v:IsA('MeshPart') or v:IsA('BasePart') then
                    -- Store original properties
                    if not OGGunProps[v] then
                        OGGunProps[v] = {
                            Material = v.Material,
                            Color = v.Color,
                            TextureID = v:IsA('MeshPart') and v.TextureID or nil
                        }
                    end
                    
                    -- Apply Gun Chams
                    local materialName = cfg.ToolMaterial or "Neon"
                    local materialEnum = Enum.Material[materialName] or Enum.Material.Neon
                    v.Material = materialEnum
                    v.Color = cfg.ToolMaterialColor or Color3.fromRGB(102, 60, 153)
                    if v:IsA('MeshPart') then
                        v.TextureID = ''
                    end
                end
            end
        else
            -- Restore original properties
            for part, props in pairs(OGGunProps) do
                if part and part.Parent then
                    pcall(function()
                        part.Material = props.Material
                        part.Color = props.Color
                        if props.TextureID and part:IsA('MeshPart') then
                            part.TextureID = props.TextureID
                        end
                    end)
                end
            end
            OGGunProps = {}
        end
    end)
end

