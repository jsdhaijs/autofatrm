-- Self Chams Render Code
function initSelfChams()
    local originalMaterials = {}
    local originalColors = {}
    local trailObject = nil
    
    RunService.RenderStepped:Connect(function()
        local char = game.Players.LocalPlayer.Character
        if not char then return end
        
        local cfg = getConfig() and getConfig().Visuals and getConfig().Visuals.SelfCharacter
        if not cfg then return end
        
        -- Apply Self Chams
        if cfg.SelfEnabled then
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA('BasePart') and not v:IsA('Tool') then
                    if not originalMaterials[v] then
                        originalMaterials[v] = v.Material
                        originalColors[v] = v.Color
                    end
                    
                    local materialEnum = Enum.Material[cfg.SelfMaterial] or Enum.Material.ForceField
                    v.Material = materialEnum
                    v.Color = cfg.SelfColor
                end
                
                -- Remove clothes if enabled
                if cfg.RemoveClothes then
                    if v:IsA('Shirt') or v:IsA('Pants') then
                        v:Destroy()
                    end
                end
            end
        else
            -- Restore originals
            for part, mat in pairs(originalMaterials) do
                if part and part.Parent then
                    part.Material = mat
                    part.Color = originalColors[part]
                end
            end
            originalMaterials = {}
            originalColors = {}
        end
        
        -- Apply Trail
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if cfg.TrailEnabled and rootPart then
            if not trailObject or not trailObject.Parent then
                trailObject = Instance.new("Trail")
                trailObject.Name = "SelfTrail"
                trailObject.Parent = rootPart
                
                local att0 = Instance.new("Attachment", rootPart)
                local att1 = Instance.new("Attachment", rootPart)
                att0.Position = Vector3.new(0, 1.5, 0)
                att1.Position = Vector3.new(0, -1.5, 0)
                trailObject.Attachment0 = att0
                trailObject.Attachment1 = att1
            end
            
            trailObject.Color = ColorSequence.new(cfg.TrailColor)
            trailObject.Lifetime = cfg.TrailDuration or 0.5
            trailObject.WidthScale = NumberSequence.new(cfg.TrailWidth or 1.6)
            trailObject.Enabled = true
        elseif trailObject then
            trailObject.Enabled = false
        end
    end)
end

-- Call it
initSelfChams()




