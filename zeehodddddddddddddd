local function AnimPlay(ID, SPEED)
    local char = game.Players.LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    if currentAnimation then
        currentAnimation:Stop()
    end

    local animation = Instance.new('Animation')
    animation.AnimationId = 'rbxassetid://' .. ID

    currentAnimation = humanoid:LoadAnimation(animation)
    currentAnimation.Priority = Enum.AnimationPriority.Action
    currentAnimation:Play()
    currentAnimation:AdjustSpeed(SPEED)

    currentAnimationID = ID
    currentSpeed = SPEED
end

local function handleAnimation()
    local cfg = (library and library.astral_config) or Astral
    if not cfg or not cfg.Animations then return end
    
    if cfg.Animations.Enabled and cfg.Animations.UseEmotes then
        local selectedDance = DancesStored[cfg.Animations.Animation]
        local newSpeed = tonumber(cfg.Animations.Speed) or 1

        if selectedDance and (not currentAnimation or not currentAnimation.IsPlaying or currentAnimationID ~= selectedDance or currentSpeed ~= newSpeed) then
            AnimPlay(selectedDance, newSpeed)
        end
    else
        if currentAnimation then
            currentAnimation:Stop()
            currentAnimation = nil
            currentAnimationID = nil
            currentSpeed = nil
        end
    end
end

