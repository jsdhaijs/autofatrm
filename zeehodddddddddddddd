-- Ping sampling for auto prediction (fewer samples = faster reaction to ping spikes during fights)
local _pingSamples = {}
local _pingSampleMax = 5
local function getPingMsRaw()
    local p = 0
    pcall(function()
        if player and type(player.GetNetworkPing) == "function" then
            local sec = player:GetNetworkPing()
            if type(sec) == "number" then p = sec * 1000; return end
        end
        local n = stats:FindFirstChild("Network")
        if not n then return end
        local item = n:FindFirstChild("ServerStatsItem")
        if item then
            local pingObj = item:FindFirstChild("Data Ping")
            if pingObj and type(pingObj.GetValue) == "function" then
                p = tonumber(pingObj:GetValue()) or 0
            end
        end
    end)
    return math.clamp(p, 0, 1000)
end

local function getPingMs()
    local raw = getPingMsRaw()
    _pingSamples[#_pingSamples + 1] = raw
    if #_pingSamples > _pingSampleMax then table.remove(_pingSamples, 1) end
    if #_pingSamples == 0 then return raw end
    local sum = 0
    for _, v in ipairs(_pingSamples) do sum = sum + v end
    return sum / #_pingSamples
end

-- Auto prediction: prediction time = your ping in seconds (1:1). 80ms ping = 0.08s lead. When ping is 0/unreported, returns nil so callers can fall back to manual.
